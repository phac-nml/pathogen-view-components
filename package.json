{
  "name": "pathogen_view_components",
  "version": "0.1.0",
  "description": "Stimulus controllers for Pathogen ViewComponents library",
  "main": "app/assets/javascripts/pathogen_view_components.js",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "format": "prettier --write . && eslint app/assets/javascripts test/javascript --fix",
    "format:changed": "prettier --write . && eslint app/assets/javascripts test/javascript --fix",
    "herb:format": "herb-format",
    "herb:format:check": "herb-format --check",
    "herb:lint": "herb-lint",
    "test": "vitest run",
    "test:unit": "vitest run test/javascript",
    "lint": "prettier --check . && eslint app/assets/javascripts test/javascript && pnpm herb:lint",
    "lint:fix": "prettier --write . && eslint app/assets/javascripts test/javascript --fix",
    "build:css": "node scripts/build-pathogen-tailwind.mjs",
    "build:css:check": "node scripts/build-pathogen-tailwind.mjs --check",
    "build:css:watch": "node scripts/watch-pathogen-css.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@herb-tools/formatter": "^0.10.1",
    "@herb-tools/linter": "^0.10.1",
    "@tailwindcss/cli": "^4.3.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "axe-core": "^4.12.1",
    "chokidar": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@hotwired/stimulus": "^3.0.0",
    "uuid": "^14.0.1"
  },
  "peerDependencies": {
    "@hotwired/turbo-rails": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.6",
      "undici": "^7.28.0",
      "esbuild": "^0.28.1"
    }
  },
  "license": "MIT"
}
