{
  // ── Global editor ──────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.rulers": [120],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ── Ruby (ruby-lsp + RuboCop) ───────────────────────────────────────────────
  "[ruby]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.rubocop": "explicit"
    }
  },
  "rubyLsp.rubyVersionManager": {
    // nix/devenv manages Ruby — no version manager needed
    "identifier": "none"
  },

  // ── ERB ────────────────────────────────────────────────────────────────────
  "[erb]": {
    "editor.defaultFormatter": "marcoroth.herb-lsp",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },
  "languageServerHerb.linter.enabled": true,
  "languageServerHerb.formatter.enabled": true,

  // ── JavaScript ─────────────────────────────────────────────────────────────
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // ── CSS / YAML / JSON ───────────────────────────────────────────────────────
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "prettier.requireConfig": true,

  // ── Package manager ─────────────────────────────────────────────────────────
  "npm.packageManager": "pnpm",

  // ── File exclusions ─────────────────────────────────────────────────────────
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/.direnv": true,
    "**/.devenv": true,
    "**/tmp": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/tmp": true,
    "**/log": true,
    "**/.direnv": true,
    "**/.devenv": true,
    "**/coverage": true
  }
}
