<% scenarios = scenarios.filter(&:visible?) %>

<% if scenarios.many? %>
  <% scenarios.each do |scenario| %>
    <div class="lookbook-scenario">
      <h6 class="lookbook-scenario__label">
        <%= scenario.label %>
      </h6>

      <%= scenario.output %>
    </div>
  <% end %>
<% elsif scenarios.first %>
  <%= scenarios.first.output %>
<% end %>
