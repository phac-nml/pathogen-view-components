<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Semantic structure</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Typography components render real heading and paragraph elements. Screen readers use level and document order — not
      visual size alone.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_heading(level: 1) { "SPEC-2026-00891" } %>

      <%= pathogen_heading(level: 2, class: "mt-6") { "Collection" } %>
      <%= pathogen_text(class: "mt-2") { "Nasopharyngeal swab · collected 2026-06-09." } %>

      <%= pathogen_heading(level: 3, class: "mt-6") { "Laboratory" } %>
      <%= pathogen_text(class: "mt-2") { "Culture negative. WGS in progress." } %>

      <%= pathogen_list(class: "mt-3") do |list| %>
        <%= list.with_item { "Specimen accessioned" } %>
        <%= list.with_item { "Nucleic acid extraction complete" } %>
        <%= list.with_item { "Library prep queued" } %>
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Label association</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Supporting text can render as a <code class="font-mono">label</code> element with a
      <code class="font-mono">for</code> attribute for form fields.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_supporting(tag: :label, for: "accession-id", class: "mb-1 block font-semibold") { "Accession ID" } %>
      <%= pathogen_supporting(variant: :muted, id: "accession-help") { "Matches the barcode on the specimen tube." } %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Do not skip heading levels within a region. Pair labels with controls using
      <code class="font-mono">for</code>/<code class="font-mono">id</code> or an enclosing
      <code class="font-mono">label</code>. Reserve <code class="font-mono">variant: :inverse</code> for dark or inverted
      surfaces only.
    </p>
  </div>
</div>
