<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Specimen detail page</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Article preset for a record header, followed by sectioned body copy and a protocol note.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_typography_preset(:article) do |group| %>
        <%= group.with_heading { "SPEC-2026-00891" } %>
        <%= group.with_metadata { "Collected 2026-06-09 · Nasopharyngeal swab · Provincial public health lab" } %>
      <% end %>

      <%= pathogen_lead(class: "mt-4") do %>
        Specimen queued for WGS bacterial v3.2 after negative culture. Paired isolate SPEC-2026-00891-A awaits library prep.
      <% end %>

      <%= pathogen_section(level: 2, class: "mt-6") do |section| %>
        <% section.with_heading { "Processing status" } %>

        <%= pathogen_list(class: "mt-3") do |list| %>
          <%= list.with_item { "Accessioned" } %>
          <%= list.with_item { "Extraction complete" } %>
          <%= list.with_item { "Library prep in progress" } %>
        <% end %>

        <%= pathogen_callout(variant: :muted, class: "mt-4") do %>
          Release blocked until contig 3 coverage is reviewed by a second operator.
        <% end %>
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Active projects grid</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Card preset for compact list rows. Section preset for a workspace region title.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_typography_preset(:section) do |group| %>
        <%= group.with_heading { "Active projects" } %>
        <%= group.with_metadata { "Updated 2 minutes ago" } %>
      <% end %>

      <div class="mt-4 space-y-3">
        <div class="border-b border-[var(--pvc-color-border)] pb-3">
          <%= pathogen_typography_preset(:card) do |group| %>
            <%= group.with_heading { "COVID-19 Analysis" } %>
            <%= group.with_metadata { "45 samples · Running" } %>
          <% end %>
        </div>

        <div class="border-b border-[var(--pvc-color-border)] pb-3">
          <%= pathogen_typography_preset(:card) do |group| %>
            <%= group.with_heading { "Influenza Study" } %>
            <%= group.with_metadata { "128 samples · Active" } %>
          <% end %>
        </div>

        <div>
          <%= pathogen_typography_preset(:card) do |group| %>
            <%= group.with_heading { "Pathogen Typing" } %>
            <%= group.with_metadata { "Completed 1h ago" } %>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Confirm destructive action</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_typography_preset(:dialog) do |group| %>
        <%= group.with_heading { "Delete sequencing run?" } %>
      <% end %>

      <%= pathogen_text(variant: :muted, class: "mt-3") do %>
        RUN-2026-0142 and associated QC artifacts will be removed. This cannot be undone.
      <% end %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      <code class="font-mono">pathogen_typography_preset</code> wraps HeadingGroup with preset level and spacing. Available
      presets: article, card, section, dialog, and form_section.
    </p>
  </div>
</div>
