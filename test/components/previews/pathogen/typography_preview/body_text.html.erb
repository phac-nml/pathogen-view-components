<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Run review narrative</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Body, lead, and callout components for explanatory copy on detail pages. Lead opens a section; callout highlights
      a single constraint or note.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_heading(level: 2) { "QC review notes" } %>

      <%= pathogen_lead(class: "mt-3") do %>
        Two specimens failed initial read-depth thresholds. Release is blocked until an operator confirms override or
        requests re-sequencing.
      <% end %>

      <%= pathogen_text(class: "mt-4") do %>
        Mean Q30 across passed lanes remains above the protocol minimum. PhiX alignment rate on lane 2 is elevated and
        should be reviewed against the run worksheet before sign-off.
      <% end %>

      <%= pathogen_callout(variant: :muted, class: "mt-4") do %>
        Override requires a documented reason and secondary approval when coverage falls below 30× on any target contig.
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Text colour variants</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 space-y-2">
      <%= pathogen_text(variant: :default) { "Default body copy for primary explanations." } %>
      <%= pathogen_text(variant: :muted) { "Muted copy for secondary detail and helper text." } %>
      <%= pathogen_text(variant: :subdued) { "Subdued copy for de-emphasised context." } %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Use <code class="font-mono">pathogen_text</code> for paragraphs, <code class="font-mono">pathogen_lead</code> for
      section openers, and <code class="font-mono">pathogen_callout</code> for emphasised constraints.
    </p>
  </div>
</div>
