<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Sequencing run header</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Typical page chrome for a run detail view. Page title, metadata, and section headings use the role-based
      <code class="font-mono">--type-*</code> scale.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_typography_preset(:article) do |group| %>
        <%= group.with_heading { "RUN-2026-0142" } %>
        <%= group.with_metadata { "NovaSeq X Plus · Submitted 2026-06-10 14:32 UTC · lab-seq-review" } %>
      <% end %>

      <%= pathogen_lead(class: "mt-4") do %>
        48 specimens submitted for WGS bacterial v3.2. Initial QC passed on 46 samples; two require review before
        pipeline release.
      <% end %>

      <%= pathogen_section(level: 2, class: "mt-6") do |section| %>
        <% section.with_heading { "QC summary" } %>

        <dl class="grid gap-3 text-sm sm:grid-cols-2">
          <div>
            <dt class="font-semibold text-[var(--pvc-color-text)]">Mean Q30</dt>
            <dd class="text-[var(--pvc-color-text-muted)]">92.4%</dd>
          </div>
          <div>
            <dt class="font-semibold text-[var(--pvc-color-text)]">Status</dt>
            <dd class="text-[var(--pvc-color-success)]">Ready for review</dd>
          </div>
        </dl>
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Type scale reference</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Role tokens used by typography components. Most product copy stays at control (14px) and body (16px).
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <dl class="space-y-3 text-sm">
        <div class="flex items-baseline justify-between gap-4 border-b border-[var(--pvc-color-border)] pb-2">
          <dt class="font-semibold text-[var(--pvc-color-text)]">Page title</dt>
          <dd class="font-mono text-[var(--pvc-color-text-muted)]">--type-page · 32px</dd>
        </div>
        <div class="flex items-baseline justify-between gap-4 border-b border-[var(--pvc-color-border)] pb-2">
          <dt class="font-semibold text-[var(--pvc-color-text)]">Section / lead</dt>
          <dd class="font-mono text-[var(--pvc-color-text-muted)]">--type-section · 20px</dd>
        </div>
        <div class="flex items-baseline justify-between gap-4 border-b border-[var(--pvc-color-border)] pb-2">
          <dt class="font-semibold text-[var(--pvc-color-text)]">Body</dt>
          <dd class="font-mono text-[var(--pvc-color-text-muted)]">--type-body · 16px</dd>
        </div>
        <div class="flex items-baseline justify-between gap-4 border-b border-[var(--pvc-color-border)] pb-2">
          <dt class="font-semibold text-[var(--pvc-color-text)]">Label / caption</dt>
          <dd class="font-mono text-[var(--pvc-color-text-muted)]">--type-control · 14px</dd>
        </div>
        <div class="flex items-baseline justify-between gap-4">
          <dt class="font-semibold text-[var(--pvc-color-text)]">Metadata / footnote</dt>
          <dd class="font-mono text-[var(--pvc-color-text-muted)]">--type-meta · 12px</dd>
        </div>
      </dl>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Prefer pathogen helpers over raw Tailwind size utilities. Page titles belong in
      <code class="font-mono">pathogen_heading</code> level 1 only.
    </p>
  </div>
</div>
