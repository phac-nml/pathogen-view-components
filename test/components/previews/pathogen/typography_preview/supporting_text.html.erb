<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Sample intake form</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Control scale for labels and help text; meta scale for timestamps and record metadata lines.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_heading(level: 2) { "Register specimen" } %>

      <%= pathogen_supporting(variant: :muted, size: :meta, class: "mt-1") do %>
        Required fields marked below · Draft saved 2026-06-10 09:14 UTC
      <% end %>

      <div class="mt-6 space-y-4">
        <div>
          <%= pathogen_supporting(tag: :label, for: "specimen-id", class: "mb-1 block font-semibold") { "Specimen ID" } %>
          <%= pathogen_supporting(variant: :muted) { "Use the barcode from the accession label." } %>
        </div>

        <div>
          <%= pathogen_supporting(tag: :label, for: "collection-date", class: "mb-1 block font-semibold") { "Collection date" } %>
          <%= pathogen_supporting(variant: :muted) { "Local date at the collection site." } %>
        </div>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Grid footnote</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <dl class="grid gap-3 text-sm sm:grid-cols-2">
        <div>
          <dt class="font-semibold text-[var(--pvc-color-text)]">Specimen ID</dt>
          <dd class="font-mono text-[var(--pvc-color-text-muted)]">SPEC-2026-00891</dd>
        </div>
        <div>
          <dt class="font-semibold text-[var(--pvc-color-text)]">Collected</dt>
          <dd class="text-[var(--pvc-color-text-muted)]">2026-06-09</dd>
        </div>
      </dl>

      <%= pathogen_supporting(variant: :muted, size: :meta, class: "mt-3") do %>
        Figure 1: Specimen metadata as shown on the intake review grid.
      <% end %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Default <code class="font-mono">pathogen_supporting</code> uses control scale. Pass
      <code class="font-mono">size: :meta</code> for timestamps and footnotes. HeadingGroup metadata defaults to meta
      scale.
    </p>
  </div>
</div>
