<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Protocol installation</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Lists, code, and section wrappers in a realistic setup flow. Section validates heading hierarchy in development.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_section(level: 2) do |section| %>
        <% section.with_heading { "Prerequisites" } %>

        <%= pathogen_list(class: "mt-3") do |list| %>
          <%= list.with_item { "PostgreSQL 14 or higher" } %>
          <%= list.with_item { "Ruby 3.3 or higher" } %>
          <%= list.with_item { "Access to the reference sequence bundle" } %>
        <% end %>
      <% end %>

      <%= pathogen_section(level: 2, class: "mt-6") do |section| %>
        <% section.with_heading { "Configure environment" } %>

        <%= pathogen_text(class: "mt-3") do %>
          Export the protocol path before running setup. Use <%= pathogen_code { "bin/setup" } %> from the application root.
        <% end %>

        <%= pathogen_code_block(language: "bash", class: "mt-3") do %>
export PROTOCOL_ROOT=/data/protocols/wgs-bacterial-v3.2
bin/setup
        <% end %>
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Card header group</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_heading_group(level: 3, spacing: :compact) do |group| %>
        <%= group.with_heading { "COVID-19 Analysis" } %>
        <%= group.with_metadata { "45 samples · Running" } %>
      <% end %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Use <code class="font-mono">pathogen_list</code> for steps, <code class="font-mono">pathogen_code</code> and
      <code class="font-mono">pathogen_code_block</code> for commands, and <code class="font-mono">pathogen_section</code>
      for bounded regions with a heading slot.
    </p>
  </div>
</div>
