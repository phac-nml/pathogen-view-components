<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Light and dark surfaces</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Typography colour variants use semantic text roles and adapt with the host theme. Toggle Lookbook dark mode to
      inspect contrast on the same markup.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_heading(level: 2) { "Operator account" } %>

      <%= pathogen_supporting(variant: :muted, size: :meta, class: "mt-1") do %>
        lab-seq-review · Provincial public health lab
      <% end %>

      <dl class="mt-4 space-y-3 text-sm">
        <div class="flex gap-2 border-b border-[var(--pvc-color-border)] pb-2">
          <dt class="w-28 shrink-0 font-semibold text-[var(--pvc-color-text)]">Display name</dt>
          <dd class="text-[var(--pvc-color-text-muted)]">lab-seq-review</dd>
        </div>
        <div class="flex gap-2">
          <dt class="w-28 shrink-0 font-semibold text-[var(--pvc-color-text)]">Email</dt>
          <dd class="text-[var(--pvc-color-text-muted)]">seq.review@example.ca</dd>
        </div>
      </dl>

      <%= pathogen_text(variant: :muted, class: "mt-4") do %>
        Notification preferences apply to QC failure alerts and run completion events.
      <% end %>

      <%= pathogen_callout(class: "mt-4") do %>
        Inverse variant is reserved for text on inverted or overlay surfaces — not everyday page copy.
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Inline code on surface</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_text do %>
        Run ID <%= pathogen_code { "RUN-2026-0142" } %> is referenced by the QC panel and export jobs.
      <% end %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Prefer <code class="font-mono">variant: :muted</code> for secondary copy. Validate WCAG AA contrast in both themes
      before shipping new surfaces.
    </p>
  </div>
</div>
