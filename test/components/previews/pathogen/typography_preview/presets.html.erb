<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Preset summary</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Pre-configured <code class="font-mono">HeadingGroup</code> levels and spacing for common product surfaces.
    </p>

    <dl class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 space-y-3 text-sm">
      <div class="flex gap-4 border-b border-[var(--pvc-color-border)] pb-2">
        <dt class="w-24 shrink-0 font-semibold text-[var(--pvc-color-text)]">:article</dt>
        <dd class="text-[var(--pvc-color-text-muted)]">h1 · default spacing · record or page header</dd>
      </div>
      <div class="flex gap-4 border-b border-[var(--pvc-color-border)] pb-2">
        <dt class="w-24 shrink-0 font-semibold text-[var(--pvc-color-text)]">:section</dt>
        <dd class="text-[var(--pvc-color-text-muted)]">h2 · default spacing · workspace region</dd>
      </div>
      <div class="flex gap-4 border-b border-[var(--pvc-color-border)] pb-2">
        <dt class="w-24 shrink-0 font-semibold text-[var(--pvc-color-text)]">:card</dt>
        <dd class="text-[var(--pvc-color-text-muted)]">h3 · compact spacing · list row or tile</dd>
      </div>
      <div class="flex gap-4 border-b border-[var(--pvc-color-border)] pb-2">
        <dt class="w-24 shrink-0 font-semibold text-[var(--pvc-color-text)]">:dialog</dt>
        <dd class="text-[var(--pvc-color-text-muted)]">h2 · compact spacing · modal title</dd>
      </div>
      <div class="flex gap-4">
        <dt class="w-24 shrink-0 font-semibold text-[var(--pvc-color-text)]">:form_section</dt>
        <dd class="text-[var(--pvc-color-text-muted)]">h3 · compact spacing · grouped fields</dd>
      </div>
    </dl>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Form section preset</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_typography_preset(:form_section) do |group| %>
        <%= group.with_heading { "Specimen metadata" } %>
        <%= group.with_metadata { "Required for accessioning" } %>
      <% end %>

      <div class="mt-4 space-y-3">
        <%= pathogen_supporting(tag: :label, for: "preset-specimen-id", class: "block font-semibold") { "Specimen ID" } %>
        <%= pathogen_supporting(variant: :muted) { "Barcode from the accession label." } %>

        <%= pathogen_supporting(tag: :label, for: "preset-collection-site", class: "block font-semibold") { "Collection site" } %>
        <%= pathogen_supporting(variant: :muted) { "Facility code from the submitter manifest." } %>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Article preset</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_typography_preset(:article) do |group| %>
        <%= group.with_heading { "WGS bacterial v3.2 release notes" } %>
        <%= group.with_metadata { "Published 2026-05-28 · Bioinformatics team" } %>
      <% end %>

      <%= pathogen_text(class: "mt-4") do %>
        Coverage thresholds and QC gates were updated for low-biomass respiratory specimens.
      <% end %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Pass <code class="font-mono">with_heading</code> and optional <code class="font-mono">with_metadata</code> to the
      preset block. Override level or spacing via helper arguments when a preset is close but not exact.
    </p>
    <pre class="mt-2 overflow-x-auto rounded-[var(--pvc-radius-control)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-3 text-xs text-[var(--pvc-color-text)]"><code>&lt;%= pathogen_typography_preset(:card) do |group| %&gt;
  &lt;%= group.with_heading { "Card title" } %&gt;
  &lt;%= group.with_metadata { "Metadata" } %&gt;
&lt;% end %&gt;</code></pre>
  </div>
</div>
