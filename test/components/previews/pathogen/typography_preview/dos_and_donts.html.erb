<div class="p-8 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800 min-h-screen">
  <!-- Header -->
  <div class="mb-12 text-center">
    <%= pathogen_heading(level: 1, class: "mb-4") do %>
      <%= icon('lightbulb', class: "text-yellow-500 dark:text-yellow-400 w-5 h-5 flex-shrink-0 inline mr-3") %> Do's and
      Don'ts
    <% end %>

    <%= pathogen_text(variant: :muted, class: "text-lg max-w-3xl mx-auto") do %>
      Best practices and common mistakes when using typography components.
    <% end %>
  </div>

  <!-- Heading Hierarchy -->
  <div class="mb-12">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 p-8">
      <%= pathogen_heading(level: 2, class: "mb-6 flex items-center") do %>
        <%= icon('list-numbers', class: "text-slate-500 dark:text-slate-400 w-5 h-5 flex-shrink-0 mr-3") %> Heading
        Hierarchy
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Do -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('check-circle', class: "w-5 h-5 flex-shrink-0 text-green-500 dark:text-green-400") %>
            <span class="font-semibold text-green-700 dark:text-green-400">Do</span>
          </div>

          <div class="space-y-3 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Use Sequential Levels
            <% end %>

            <%= pathogen_heading(level: 1) do %>
              Main Title
            <% end %>

            <%= pathogen_heading(level: 2) do %>
              Section
            <% end %>

            <%= pathogen_heading(level: 3) do %>
              Subsection
            <% end %>

            <%= pathogen_text(variant: :muted, class: "text-sm mt-3") do %>
              Use headings in order (h1 → h2 → h3) without skipping levels
            <% end %>
          </div>
        </div>

        <!-- Don't -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('x-circle', class: "w-5 h-5 flex-shrink-0 text-red-500 dark:text-red-400") %>
            <span class="font-semibold text-red-700 dark:text-red-400">Don't</span>
          </div>

          <div class="space-y-3 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Skip Heading Levels
            <% end %>

            <%= pathogen_heading(level: 1) do %>
              Main Title
            <% end %>

            <%= pathogen_heading(level: 3) do %>
              Skipped H2
            <% end %>

            <%= pathogen_text(variant: :muted, class: "text-sm mt-3") do %>
              Never skip heading levels - it breaks accessibility and SEO
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Color Usage -->
  <div class="mb-12">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 p-8">
      <%= pathogen_heading(level: 2, class: "mb-6 flex items-center") do %>
        <%= icon('palette', class: "text-slate-500 dark:text-slate-400 w-5 h-5 flex-shrink-0 mr-3") %> Color Variants
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Do -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('check-circle', class: "w-5 h-5 flex-shrink-0 text-green-500 dark:text-green-400") %>
            <span class="font-semibold text-green-700 dark:text-green-400">Do</span>
          </div>

          <div class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Use Variants Appropriately
            <% end %>

            <%= pathogen_text(variant: :default) do %>
              Default for primary content
            <% end %>

            <%= pathogen_text(variant: :muted) do %>
              Muted for secondary information
            <% end %>
          </div>
        </div>

        <!-- Don't -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('x-circle', class: "w-5 h-5 flex-shrink-0 text-red-500 dark:text-red-400") %>
            <span class="font-semibold text-red-700 dark:text-red-400">Don't</span>
          </div>

          <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Overuse Muted Text
            <% end %>

            <%= pathogen_text(variant: :muted) do %>
              Don't make everything muted - it reduces readability
            <% end %>

            <%= pathogen_text(variant: :muted) do %>
              Use muted sparingly for less important content
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Code Usage -->
  <div class="mb-12">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 p-8">
      <%= pathogen_heading(level: 2, class: "mb-6 flex items-center") do %>
        <%= icon('code', class: "text-slate-500 dark:text-slate-400 w-5 h-5 flex-shrink-0 mr-3") %> Code Component Usage
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Do -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('check-circle', class: "w-5 h-5 flex-shrink-0 text-green-500 dark:text-green-400") %>
            <span class="font-semibold text-green-700 dark:text-green-400">Do</span>
          </div>

          <div class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Use Appropriate Component
            <% end %>

            <%= pathogen_text do %>
              Use
              <%= pathogen_code do %>
                inline code
              <% end %>
              for short snippets
            <% end %>

            <%= pathogen_code_block(language: "ruby") do %>
              def example # Use code_block for multi-line code end
            <% end %>
          </div>
        </div>

        <!-- Don't -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('x-circle', class: "w-5 h-5 flex-shrink-0 text-red-500 dark:text-red-400") %>
            <span class="font-semibold text-red-700 dark:text-red-400">Don't</span>
          </div>

          <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Mix Inline and Block
            <% end %>

            <%= pathogen_text do %>
              Don't use code_block for single words - use inline code instead
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Baseline Sizing -->
  <div class="mb-12">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 p-8">
      <%= pathogen_heading(level: 2, class: "mb-6 flex items-center") do %>
        <%= icon('device-mobile', class: "text-slate-500 dark:text-slate-400 w-5 h-5 flex-shrink-0 mr-3") %> Responsive
        Behavior
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Do -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('check-circle', class: "w-5 h-5 flex-shrink-0 text-green-500 dark:text-green-400") %>
            <span class="font-semibold text-green-700 dark:text-green-400">Do</span>
          </div>

          <div class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Use Baseline Heading Sizes
            <% end %>

            <%= pathogen_text(variant: :muted, class: "text-sm") do %>
              Use the semantic heading level that matches the content hierarchy
            <% end %>
          </div>
        </div>

        <!-- Don't -->
        <div>
          <div class="flex items-center gap-3 mb-4">
            <%= icon('x-circle', class: "w-5 h-5 flex-shrink-0 text-red-500 dark:text-red-400") %>
            <span class="font-semibold text-red-700 dark:text-red-400">Don't</span>
          </div>

          <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
            <%= pathogen_heading(level: 3) do %>
              Override Sizes Unnecessarily
            <% end %>

            <%= pathogen_heading(level: 1, responsive: false) do %>
              Fixed Size Heading
            <% end %>

            <%= pathogen_text(variant: :muted, class: "text-sm mt-3") do %>
              Avoid forcing heading sizes away from the typography scale
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Best Practices Summary -->
  <div>
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 p-8">
      <%= pathogen_heading(level: 2, class: "mb-6 flex items-center") do %>
        <%= icon('star', class: "text-yellow-500 dark:text-yellow-400 w-5 h-5 flex-shrink-0 mr-3") %> Best Practices
        Summary
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div class="font-semibold text-green-700 dark:text-green-400 mb-3 flex items-center">
            <%= icon('check-circle', class: "text-green-500 dark:text-green-400 w-5 h-5 flex-shrink-0 mr-2") %> Do's
          </div>

          <%= pathogen_list do |list| %>
            <%= list.with_item { 'Maintain proper heading hierarchy (h1 → h2 → h3)' } %>
            <%= list.with_item { 'Choose appropriate components for content type' } %>
            <%= list.with_item { 'Use the baseline typography scale consistently' } %>
            <%= list.with_item { 'Use semantic HTML elements' } %>
            <%= list.with_item { 'Test with screen readers' } %>
          <% end %>
        </div>

        <div>
          <div class="font-semibold text-red-700 dark:text-red-400 mb-3 flex items-center">
            <%= icon('x-circle', class: "text-red-500 dark:text-red-400 w-5 h-5 flex-shrink-0 mr-2") %> Don'ts
          </div>

          <%= pathogen_list do |list| %>
            <%= list.with_item { "Don't skip heading levels" } %>
            <%= list.with_item { "Don't overuse muted text variants" } %>
            <%= list.with_item { "Don't override typography sizes unnecessarily" } %>
            <%= list.with_item { "Don't use divs instead of semantic elements" } %>
            <%= list.with_item { "Don't ignore accessibility requirements" } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
