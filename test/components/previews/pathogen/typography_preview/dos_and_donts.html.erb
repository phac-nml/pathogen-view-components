<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Heading hierarchy</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Use sequential levels inside a page region. Skipping levels breaks screen-reader outline and document structure.
    </p>

    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <p class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Preferred</p>

        <%= pathogen_heading(level: 2) { "Run review" } %>
        <%= pathogen_heading(level: 3, class: "mt-4") { "QC summary" } %>
        <%= pathogen_heading(level: 4, class: "mt-4") { "Lane metrics" } %>
      </div>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4">
        <p class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Avoid</p>

        <%= pathogen_heading(level: 2) { "Run review" } %>
        <%= pathogen_heading(level: 4, class: "mt-4") { "Skipped h3" } %>

        <p class="mt-4 text-sm text-[var(--pvc-color-text-muted)]">
          Level 4 follows level 2 with no intervening section.
        </p>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Sizing and emphasis</h2>

    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <p class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Preferred</p>

        <%= pathogen_heading(level: 1) { "RUN-2026-0142" } %>
        <%= pathogen_text(variant: :muted, class: "mt-2") { "Use component levels for hierarchy." } %>
      </div>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4">
        <p class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Avoid</p>

        <%= pathogen_heading(level: 1, class: "text-sm") { "Shrunken page title" } %>

        <p class="mt-4 text-sm text-[var(--pvc-color-text-muted)]">
          Custom size classes defeat the shared type scale.
        </p>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Code in copy</h2>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_text do %>
        Call <%= pathogen_code { "pathogen_heading" } %> for titles and <%= pathogen_code { "pathogen_code" } %> for
        identifiers such as <%= pathogen_code { "RUN-2026-0142" } %>.
      <% end %>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      One page title per view. Muted variants for secondary copy. No decorative uppercase labels — use
      <code class="font-mono">pathogen_supporting</code> with <code class="font-mono">size: :meta</code> for metadata
      lines.
    </p>
  </div>
</div>
