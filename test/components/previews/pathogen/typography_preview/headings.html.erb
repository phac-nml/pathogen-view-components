<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Specimen record headings</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Semantic levels map to role tokens. Use sequential h1–h6 without skipping levels inside a page region.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_heading(level: 1) { "SPEC-2026-00891" } %>

      <%= pathogen_supporting(variant: :muted, size: :meta, class: "mt-1") do %>
        Collected 2026-06-09 · Provincial public health lab
      <% end %>

      <%= pathogen_heading(level: 2, class: "mt-6") { "Collection details" } %>

      <%= pathogen_text(class: "mt-2") do %>
        Nasopharyngeal swab received at the reference laboratory under cold-chain protocol B-12.
      <% end %>

      <%= pathogen_heading(level: 3, class: "mt-6") { "Lab results" } %>

      <%= pathogen_text(class: "mt-2") do %>
        Culture negative. WGS pending on paired isolate SPEC-2026-00891-A.
      <% end %>

      <%= pathogen_heading(level: 4, class: "mt-6") { "QC flags" } %>

      <%= pathogen_text(variant: :muted, class: "mt-2") do %>
        Coverage below threshold on contig 3 — review required before release.
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Colour variants</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Default for primary labels; muted for secondary section titles; subdued and inverse for constrained surfaces.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 space-y-3">
      <%= pathogen_heading(level: 3, variant: :default) { "Default section title" } %>
      <%= pathogen_heading(level: 3, variant: :muted) { "Muted section title" } %>
      <%= pathogen_heading(level: 3, variant: :subdued) { "Subdued section title" } %>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-neutral-900 p-3 dark:bg-neutral-100">
        <%= pathogen_heading(level: 3, variant: :inverse) { "Inverse section title" } %>
      </div>
    </div>
  </section>

  <div class="rounded-md border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4 text-sm text-[var(--pvc-color-text-muted)]">
    <p class="font-semibold text-[var(--pvc-color-text)]">Usage</p>
    <p class="mt-2">
      Use sequential heading levels inside a page region. Do not override page-title sizing with custom classes;
      hierarchy comes from level, weight, and placement.
    </p>
    <pre class="mt-2 overflow-x-auto rounded-[var(--pvc-radius-control)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-3 text-xs text-[var(--pvc-color-text)]"><code>&lt;%= pathogen_heading(level: 2) { "Section" } %&gt;</code></pre>
  </div>
</div>
