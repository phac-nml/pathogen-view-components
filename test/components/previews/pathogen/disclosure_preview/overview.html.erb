<div class="flex max-w-lg flex-col gap-8 p-4">
  <section class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
    <%= pathogen_heading(level: 3, class: "mb-2") { "Closed by default" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use a disclosure for optional detail that stays out of the way until needed — for example advanced export options
      on a run.
    <% end %>

    <%= render Pathogen::Disclosure.new(id: "export-options", label: "Advanced export options") do %>
      <ul class="list-disc space-y-1 pl-5">
        <li>Include quality metrics CSV</li>
        <li>Attach protocol PDF</li>
        <li>Notify watchers on completion</li>
      </ul>
    <% end %>
  </section>

  <section class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
    <%= pathogen_heading(level: 3, class: "mb-2") { "Open by default" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Start open when the section is part of the primary workflow (for example project settings already in use).
    <% end %>

    <%= render Pathogen::Disclosure.new(id: "project-settings", label: "Project settings", open: true) do %>
      <ul class="space-y-1">
        <li>
          <%= pathogen_link(href: "#") { "General" } %>
        </li>

        <li>
          <%= pathogen_link(href: "#") { "Members" } %>
        </li>

        <li>
          <%= pathogen_link(href: "#") { "Bots" } %>
        </li>
      </ul>
    <% end %>
  </section>

  <section class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
    <%= pathogen_heading(level: 3, class: "mb-2") { "Custom trigger content" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "with_trigger" } %> for non-interactive phrasing content and provide
      <%= pathogen_code { "aria_label:" } %> for the button’s accessible name.
    <% end %>

    <%= render Pathogen::Disclosure.new(
      id: "metadata-templates",
      aria_label: "Metadata templates, 3 available"
    ) do |disclosure| %>
      <% disclosure.with_trigger do %>
        Metadata templates <span class="ml-2 text-xs font-normal text-[color:var(--pvc-color-text-muted)]">(3)</span>
      <% end %>

      <p class="text-sm">Specimen, isolate, and outbreak templates for this group.</p>
    <% end %>
  </section>
</div>
