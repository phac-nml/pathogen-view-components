<div class="flex max-w-lg flex-col gap-6 p-4">
  <section class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
    <%= pathogen_heading(level: 3, class: "mb-2") { "Keyboard and state announcements" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Tab to the button, then use Enter or Space to open and close. Focus stays on the trigger so the screen reader
      announces the new <%= pathogen_code { "aria-expanded" } %> state on activation (not only on focus).
      <%= pathogen_code { "aria-controls" } %> points at the panel. The caret is a CSS border icon
      (<%= pathogen_code { "aria-hidden" } %>) styled from <%= pathogen_code { "aria-expanded" } %>.
    <% end %>

    <%= render Pathogen::Disclosure.new(id: "a11y-settings", label: "Settings", heading_level: 3) do %>
      <ul class="space-y-1">
        <li>
          <%= pathogen_link(href: "#general") { "General" } %>
        </li>

        <li>
          <%= pathogen_link(href: "#history") { "History" } %>
        </li>
      </ul>
    <% end %>
  </section>

  <section class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
    <%= pathogen_heading(level: 3, class: "mb-2") { "Focus" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Focus the trigger with the keyboard to confirm the visible focus ring uses
      <%= pathogen_code { "--pvc-color-focus" } %>. In forced-colors, the ring falls back to Highlight.
    <% end %>

    <%= render Pathogen::Disclosure.new(id: "a11y-focus", label: "Quality control filters", open: true) do %>
      <p>Pass rate, coverage threshold, and contaminant flags for this run.</p>
    <% end %>
  </section>

  <section class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
    <%= pathogen_heading(level: 3, class: "mb-2") { "Label in Name" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Visible trigger text is the name by default. An optional richer <%= pathogen_code { "aria_label:" } %> must still
      include that visible text (WCAG 2.5.3).
    <% end %>

    <%= render Pathogen::Disclosure.new(
      id: "a11y-label-in-name",
      aria_label: "Metadata templates, 3 available"
    ) do |disclosure| %>
      <% disclosure.with_trigger do %>
        Metadata templates <span class="ml-2 text-xs font-normal text-[color:var(--pvc-color-text-muted)]">(3)</span>
      <% end %>

      <p class="text-sm">Specimen, isolate, and outbreak templates for this group.</p>
    <% end %>
  </section>
</div>
