<div class="flex max-w-3xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 5, class: "mb-2 font-semibold") { "Custom feedback message" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Override the default copied announcement with context-specific screen-reader feedback.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <dl class="grid gap-6">
        <div>
          <%= pathogen_supporting(tag: :dt, class: "mb-2 font-semibold") { "Default message" } %>

          <dd class="space-y-2">
            <%= render Pathogen::CopyableValue.new(value: "INXT_PRJ_A2G6VVJNCN") %>

            <%= pathogen_supporting(variant: :muted, class: "text-xs") do %>
              Screen reader announces: "Copied to clipboard"
            <% end %>
          </dd>
        </div>

        <div>
          <%= pathogen_supporting(tag: :dt, class: "mb-2 font-semibold") { "Custom message" } %>

          <dd class="space-y-2">
            <%= render Pathogen::CopyableValue.new(value: "INXT_PRJ_A2G6VVJNCN", copied_message: "Project ID copied!") %>

            <%= pathogen_supporting(variant: :muted, class: "text-xs") do %>
              Screen reader announces: "Project ID copied!"
            <% end %>
          </dd>
        </div>
      </dl>
    </div>
  </section>
</div>
