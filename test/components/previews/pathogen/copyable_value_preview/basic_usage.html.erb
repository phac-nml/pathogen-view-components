<div class="flex max-w-3xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 5, class: "mb-2 font-semibold") { "Basic usage" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      A compact inline identifier with an integrated copy action. Values share the inline code surface with
    <% end %>

    <%= pathogen_code { "Pathogen::Typography::Code" } %>

    <div
      class="
        mt-4 rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]
        p-4
      "
    >
      <dl class="grid gap-4">
        <div>
          <%= pathogen_supporting(tag: :dt, class: "mb-2 font-semibold") { "Project PUID" } %>

          <dd><%= render Pathogen::CopyableValue.new(value: "INXT_PRJ_A2G6VVJNCN") %></dd>
        </div>

        <div>
          <%= pathogen_supporting(tag: :dt, class: "mb-2 font-semibold") { "Sample PUID" } %>

          <dd><%= render Pathogen::CopyableValue.new(value: "INXT_SAM_B7K4WWQLDR") %></dd>
        </div>

        <div>
          <%= pathogen_supporting(tag: :dt, class: "mb-2 font-semibold") { "Short hash" } %>

          <dd><%= render Pathogen::CopyableValue.new(value: "a3f29c1") %></dd>
        </div>
      </dl>
    </div>
  </section>
</div>
