<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Tone and emphasis" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "tone" } %> for meaning and <%= pathogen_code { "emphasis" } %> for hierarchy. Existing
      <%= pathogen_code { "scheme" } %> values map to presets. Pick one combination per action group using the reference
      table below.
    <% end %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Solid primary and danger fills darken on hover through <%= pathogen_code { "--pvc-color-accent-solid-hover" } %>
      and <%= pathogen_code { "--pvc-color-danger-solid-hover" } %>. Hover a solid button to inspect the pressed-in
      effect.
    <% end %>

    <div class="overflow-x-auto rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]">
      <table class="w-full min-w-[40rem] border-collapse text-sm">
        <thead>
          <tr class="border-b border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)]">
            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Variant" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "When to use" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Example" } %>
            </th>
          </tr>
        </thead>

        <tbody class="divide-y divide-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
          <% [
            [:primary, :solid, 'Submit run', 'Main forward action per surface'],
            [:primary, :outline, 'Save draft', 'Secondary brand action'],
            [:primary, :ghost, 'View protocol', 'Quiet brand-linked action'],
            [:neutral, :outline, 'Cancel', 'Cancel, close, or secondary step'],
            [:neutral, :solid, 'Archive', 'Strong neutral action when clearer than accent'],
            [:neutral, :ghost, 'Skip', 'Tools, utilities, and low-emphasis actions'],
            [:danger, :outline, 'Discard', 'Destructive action when confirmation happens elsewhere'],
            [:danger, :solid, 'Delete permanently', 'Confirmed destructive step only'],
            [:danger, :ghost, 'Remove tag', 'Dense destructive utility in tight layouts']
          ].each do |tone, emphasis, label, guidance| %>
            <tr>
              <td class="px-4 py-3 align-middle">
                <%= pathogen_code(class: "text-xs") { "tone: #{tone}, emphasis: #{emphasis}" } %>
              </td>

              <td class="px-4 py-3 align-middle">
                <%= pathogen_supporting(tag: :span, variant: :muted) { guidance } %>
              </td>

              <td class="px-4 py-3 align-middle">
                <%= render Pathogen::Button.new(tone:, emphasis:, text: label) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= pathogen_heading(level: 5, class: "mb-2 mt-6 font-semibold") { "Legacy scheme mapping" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      <%= pathogen_code { "default" } %> maps to neutral outline, <%= pathogen_code { "primary" } %> to primary solid,
      and <%= pathogen_code { "danger" } %> to danger outline.
    <% end %>

    <div class="flex flex-wrap items-center gap-2">
      <%= render Pathogen::Button.new(scheme: :default, text: 'scheme: default') %>
      <%= render Pathogen::Button.new(scheme: :primary, text: 'scheme: primary') %>
      <%= render Pathogen::Button.new(scheme: :danger, text: 'scheme: danger') %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Form footer" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      One <%= pathogen_code { "primary + solid" } %> forward action per surface. Keep cancel and reset secondary. Place
      destructive outline actions away from the main forward step.
    <% end %>

    <form class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
      <div class="border-b border-[var(--pvc-color-border)] px-4 py-3">
        <%= pathogen_heading(level: 5, class: "font-semibold") { "Update specimen metadata" } %>
        <%= pathogen_supporting(variant: :muted, class: "mt-1") { "Changes apply to the selected isolate record." } %>
      </div>

      <div class="px-4 py-4">
        <%= pathogen_supporting(variant: :muted) { "Form fields would appear here." } %>
      </div>

      <div class="flex items-center justify-between gap-3 border-t border-[var(--pvc-color-border)] px-4 py-3">
        <%= render Pathogen::Button.new(tone: :danger, emphasis: :outline, text: 'Delete specimen') %>

        <div class="flex items-center gap-2">
          <%= render Pathogen::Button.new(tone: :neutral, emphasis: :ghost, text: 'Reset') %>
          <%= render Pathogen::Button.new(tone: :neutral, emphasis: :outline, text: 'Cancel') %>
          <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, text: 'Save changes') %>
        </div>
      </div>
    </form>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Grid toolbar" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Toolbar actions stay compact: <%= pathogen_code { "size: :small" } %>, ghost or outline emphasis, and icon-only
      controls with distinct accessible names. Keep 8px between neighbours.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
      <div class="flex items-center justify-between gap-4 border-b border-[var(--pvc-color-border)] px-4 py-3">
        <%= pathogen_heading(level: 5, class: "font-semibold") { "Sequencing submissions" } %>

        <div class="flex items-center gap-2">
          <%= render Pathogen::Button.new(icon_only: true, size: :small, tone: :neutral, emphasis: :ghost, text: 'Refresh list') do |button| %>
            <% button.with_leading_visual do %>
              <%= icon('arrow-clockwise', class: 'size-4') %>
            <% end %>
          <% end %>

          <%= render Pathogen::Button.new(icon_only: true, size: :small, tone: :neutral, emphasis: :ghost, text: 'Export CSV') do |button| %>
            <% button.with_leading_visual do %>
              <%= icon('download-simple', class: 'size-4') %>
            <% end %>
          <% end %>

          <%= render Pathogen::Button.new(size: :small, tone: :danger, emphasis: :ghost, text: 'Clear filters') %>
          <%= render Pathogen::Button.new(size: :small, tone: :neutral, emphasis: :outline, text: 'Columns') %>
          <%= render Pathogen::Button.new(size: :small, tone: :primary, emphasis: :solid, text: 'New submission') %>
        </div>
      </div>

      <div class="px-4 py-6">
        <%= pathogen_supporting(variant: :muted) { "Grid content would appear here." } %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Action groups" } %>

    <div class="flex flex-col gap-6">
      <div>
        <%= pathogen_heading(level: 5, class: "mb-2 font-semibold") { "Adjacent actions" } %>

        <%= pathogen_supporting(variant: :muted, class: "mb-3") do %>
          Group related actions with consistent spacing. One primary solid when a single option needs emphasis.
        <% end %>

        <div
          class="
            inline-flex items-center gap-2 rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
            bg-[var(--pvc-color-surface-muted)] p-3
          "
        >
          <%= render Pathogen::Button.new(size: :small, tone: :neutral, emphasis: :outline, text: 'List') %>
          <%= render Pathogen::Button.new(size: :small, tone: :neutral, emphasis: :outline, text: 'Board') %>
          <%= render Pathogen::Button.new(size: :small, tone: :primary, emphasis: :solid, text: 'Timeline') %>
        </div>
      </div>

      <div>
        <%= pathogen_heading(level: 5, class: "mb-2 font-semibold") { "Confirmation cluster" } %>

        <%= pathogen_supporting(variant: :muted, class: "mb-3") do %>
          Pair <%= pathogen_code { "danger + solid" } %> with a neutral secondary action in explicit confirmation steps.
        <% end %>

        <div class="flex items-center gap-2">
          <%= render Pathogen::Button.new(tone: :danger, emphasis: :solid, text: 'Delete run') %>
          <%= render Pathogen::Button.new(tone: :neutral, emphasis: :outline, text: 'Keep run') %>
        </div>
      </div>

      <div>
        <%= pathogen_heading(level: 5, class: "mb-2 font-semibold") { "Dense destructive utility" } %>

        <%= pathogen_supporting(variant: :muted, class: "mb-3") do %>
          Use <%= pathogen_code { "danger + ghost" } %> for low-emphasis destructive tools in tight table or list rows.
        <% end %>

        <div
          class="
            flex items-center justify-between gap-4 rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
            bg-[var(--pvc-color-surface-muted)] px-3 py-2
          "
        >
          <%= pathogen_supporting(tag: :span, variant: :muted) { "Filter: pending review" } %>
          <%= render Pathogen::Button.new(size: :small, tone: :danger, emphasis: :ghost, text: 'Remove filter') %>
        </div>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Leading and trailing visuals" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Icons are decorative. The visible label carries the accessible name. Show one primary solid per action group.
    <% end %>

    <div class="flex flex-col gap-6">
      <div>
        <%= pathogen_heading(level: 5, class: "mb-2 font-semibold") { "Leading visual" } %>

        <div class="flex flex-wrap items-center gap-2">
          <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, text: 'Search samples') do |button| %>
            <% button.with_leading_visual do %>
              <%= icon('magnifying-glass', class: 'size-4') %>
            <% end %>
          <% end %>

          <%= render Pathogen::Button.new(tone: :danger, emphasis: :outline, text: 'View alerts') do |button| %>
            <% button.with_leading_visual do %>
              <%= icon('bell', class: 'size-4') %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div>
        <%= pathogen_heading(level: 5, class: "mb-2 font-semibold") { "Trailing visual" } %>

        <div class="flex flex-wrap items-center gap-2">
          <%= render Pathogen::Button.new(tone: :primary, emphasis: :outline, text: 'Continue to review') do |button| %>
            <% button.with_trailing_visual do %>
              <%= icon('arrow-right', class: 'size-4') %>
            <% end %>
          <% end %>

          <%= render Pathogen::Button.new(tone: :neutral, emphasis: :outline, text: 'Open run details') do |button| %>
            <% button.with_trailing_visual do %>
              <%= icon('arrow-square-out', class: 'size-4') %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Link as a button" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "tag: :a" } %> with <%= pathogen_code { "href" } %> when navigation should match a button
      cluster. Prefer <%= pathogen_code { "Pathogen::Link" } %> for inline text navigation.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <div class="flex flex-wrap items-center gap-2">
        <%= render Pathogen::Button.new(tag: :a, href: '/samples', tone: :primary, emphasis: :solid, text: 'View samples') %>
        <%= render Pathogen::Button.new(tag: :a, href: '/runs/draft', tone: :primary, emphasis: :outline, text: 'Open draft') %>
        <%= render Pathogen::Button.new(tag: :a, href: '/dashboard', tone: :neutral, emphasis: :outline, text: 'Back to dashboard') %>
        <%= render Pathogen::Button.new(tag: :a, href: '/samples/42/delete', tone: :danger, emphasis: :outline, text: 'Delete sample') %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Sizes and full width" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Medium targets forms and dialogs (44px minimum). Small targets toolbars and dense tables (24px minimum).
    <% end %>

    <div class="flex flex-wrap items-center gap-2">
      <%= render Pathogen::Button.new(size: :medium, tone: :primary, emphasis: :solid, text: 'Medium') %>
      <%= render Pathogen::Button.new(size: :small, tone: :primary, emphasis: :solid, text: 'Small') %>
    </div>

    <div class="mt-4 max-w-sm">
      <%= render Pathogen::Button.new(block: true, tone: :primary, emphasis: :solid, text: 'Full width action') %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Enabled, disabled, and aria-disabled states" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "disabled: true" } %> when the control should not be focusable. Disabled buttons use
      reduced opacity and a not-allowed cursor. Use <%= pathogen_code { "aria_disabled: true" } %> when the control
      should stay focusable so validation feedback can be announced after activation.
    <% end %>

    <div class="overflow-x-auto rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]">
      <table class="w-full min-w-[48rem] border-collapse text-sm">
        <thead>
          <tr class="border-b border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)]">
            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Variant" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Enabled" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Disabled" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "aria-disabled" } %>
            </th>
          </tr>
        </thead>

        <tbody class="divide-y divide-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
          <% [
            [:primary, :solid, 'Submit run'],
            [:primary, :outline, 'Save draft'],
            [:primary, :ghost, 'View protocol'],
            [:neutral, :outline, 'Cancel'],
            [:neutral, :solid, 'Archive'],
            [:neutral, :ghost, 'Skip'],
            [:danger, :outline, 'Discard'],
            [:danger, :solid, 'Delete permanently'],
            [:danger, :ghost, 'Remove tag']
          ].each do |tone, emphasis, label| %>
            <tr>
              <td class="px-4 py-3 align-middle">
                <%= pathogen_code(class: "text-xs") { "tone: #{tone}, emphasis: #{emphasis}" } %>
              </td>

              <td class="px-4 py-3 align-middle">
                <%= render Pathogen::Button.new(tone:, emphasis:, text: label) %>
              </td>

              <td class="px-4 py-3 align-middle">
                <%= render Pathogen::Button.new(tone:, emphasis:, disabled: true, text: label) %>
              </td>

              <td class="px-4 py-3 align-middle">
                <%= render Pathogen::Button.new(tone:, emphasis:, aria_disabled: true, text: label) %>
              </td>
            </tr>
          <% end %>

          <tr>
            <td class="px-4 py-3 align-middle">
              <%= pathogen_code(class: "text-xs") { "size: :small" } %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= render Pathogen::Button.new(size: :small, tone: :primary, emphasis: :solid, text: 'New submission') %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= render Pathogen::Button.new(size: :small, tone: :primary, emphasis: :solid, disabled: true, text: 'New submission') %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= render Pathogen::Button.new(size: :small, tone: :primary, emphasis: :solid, aria_disabled: true, text: 'New submission') %>
            </td>
          </tr>

          <tr>
            <td class="px-4 py-3 align-middle">
              <%= pathogen_code(class: "text-xs") { "icon_only: true" } %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= render Pathogen::Button.new(icon_only: true, size: :small, tone: :neutral, emphasis: :ghost, text: 'Refresh list') do |button| %>
                <% button.with_leading_visual do %>
                  <%= icon('arrow-clockwise', class: 'size-4') %>
                <% end %>
              <% end %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= render Pathogen::Button.new(icon_only: true, size: :small, tone: :neutral, emphasis: :ghost, disabled: true, text: 'Refresh list') do |button| %>
                <% button.with_leading_visual do %>
                  <%= icon('arrow-clockwise', class: 'size-4') %>
                <% end %>
              <% end %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= render Pathogen::Button.new(icon_only: true, size: :small, tone: :neutral, emphasis: :ghost, aria_disabled: true, text: 'Refresh list') do |button| %>
                <% button.with_leading_visual do %>
                  <%= icon('arrow-clockwise', class: 'size-4') %>
                <% end %>
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</div>
