<div class="flex max-w-3xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Repeating button labels</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      When multiple icon-only buttons share the same visual, give each a distinct accessible name.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <h3 class="text-sm font-semibold text-[var(--pvc-color-text)]">Payment details</h3>

      <div class="mt-4 flex items-center justify-between gap-4 border-b border-[var(--pvc-color-border)] py-3">
        <span id="payment-date" class="text-sm text-[var(--pvc-color-text-muted)]">1 Jan, 2024</span>

        <%= render Pathogen::Button.new(icon_only: true, text: 'Edit payment date', size: :small) do |button| %>
          <% button.with_leading_visual do %>
            <%= icon('pencil', class: 'size-4') %>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center justify-between gap-4 py-3">
        <span id="payment-amount" class="text-sm text-[var(--pvc-color-text-muted)]">$200.00</span>

        <%= render Pathogen::Button.new(icon_only: true, text: 'Edit payment amount', size: :small) do |button| %>
          <% button.with_leading_visual do %>
            <%= icon('pencil', class: 'size-4') %>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Focusable disabled button</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Use <code class="font-mono">aria_disabled: true</code> when the action is not yet available but the button should
      remain focusable so screen reader users hear validation feedback after activation.
    </p>

    <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, aria_disabled: true, text: 'Continue') %>
  </section>
</div>
