<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Keyboard focus" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Tab through the buttons below. Focus uses <%= pathogen_code { "--pvc-color-focus" } %> (
      <%= pathogen_code { "primary-500" } %> in light and dark) so the ring stays distinct from accent colour on primary
      controls. Check both light and dark mode in Lookbook.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <div class="flex flex-wrap items-center gap-2">
        <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, text: 'Submit run') %>
        <%= render Pathogen::Button.new(tone: :primary, emphasis: :outline, text: 'Save draft') %>
        <%= render Pathogen::Button.new(tone: :neutral, emphasis: :outline, text: 'Cancel') %>

        <%= render Pathogen::Button.new(icon_only: true, size: :small, tone: :neutral, emphasis: :ghost, text: 'Refresh list') do |button| %>
          <% button.with_leading_visual do %>
            <%= icon('arrow-clockwise', class: 'size-4') %>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Collapsed sidebar rail" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Icon-only rail controls need an accessible name on the button itself (via <%= pathogen_code { "text:" } %> /
      <%= pathogen_code { "aria-label" } %>). Attach <%= pathogen_code { "with_tooltip" } %> for a sighted hover/focus
      label — the tooltip must not be the only name. On icon-only buttons the tooltip defaults to visual-only (no
      <%= pathogen_code { "aria-describedby" } %>), so the <%= pathogen_code { "aria-label" } %> is the single announced
      name with no duplicate echo; keep the tooltip text identical to that name. Use
      <%= pathogen_code { "placement: :right" } %> (a physical direction — flip it in RTL) so labels open into the
      content area. On touch, the first tap reveals the tooltip and the action fires on the second tap.
    <% end %>

    <div
      class="
        overflow-hidden rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)]
      "
    >
      <div class="flex">
        <aside
          class="
            flex w-14 flex-col items-center gap-2 border-r border-[var(--pvc-color-border)]
            bg-[var(--pvc-color-surface-muted)] py-4
          "
          aria-label="Workspace navigation"
        >
          <% [
            ["house", "Dashboard"],
            ["flask", "Specimens"],
            ["folder", "Projects"],
            ["play", "Workflows"],
            ["gear", "Settings"]
          ].each do |icon_name, label| %>
            <%= render Pathogen::Button.new(
              icon_only: true,
              size: :small,
              tone: :neutral,
              emphasis: :ghost,
              text: label
            ) do |button| %>
              <% button.with_tooltip(text: label, placement: :right) %>

              <% button.with_leading_visual do %>
                <%= icon(icon_name, class: "size-4 text-[var(--pvc-color-text-muted)]") %>
              <% end %>
            <% end %>
          <% end %>
        </aside>

        <div class="flex-1 px-4 py-4">
          <%= pathogen_supporting(variant: :muted) do %>
            Hover or focus each rail icon to read the section label. Screen readers already get the name from
            <%= pathogen_code { "aria-label" } %> on the button, so the tooltip adds no new information for them — it is
            purely a visual affordance for sighted pointer and keyboard users.
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Repeating button labels" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      When multiple icon-only buttons share the same visual, give each a distinct accessible name.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_heading(level: 5, class: "font-semibold") { "Specimen collection details" } %>

      <div class="mt-4 flex items-center justify-between gap-4 border-b border-[var(--pvc-color-border)] py-3">
        <%= pathogen_supporting(tag: :span, variant: :muted, id: "collection-date") { "Collected 12 Mar 2024" } %>

        <%= render Pathogen::Button.new(icon_only: true, text: 'Edit collection date', size: :small, tone: :neutral, emphasis: :ghost) do |button| %>
          <% button.with_leading_visual do %>
            <%= icon('pencil', class: 'size-4') %>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center justify-between gap-4 py-3">
        <%= pathogen_supporting(tag: :span, variant: :muted, id: "specimen-id") { "SP-2024-0042" } %>

        <%= render Pathogen::Button.new(icon_only: true, text: 'Edit specimen identifier', size: :small, tone: :neutral, emphasis: :ghost) do |button| %>
          <% button.with_leading_visual do %>
            <%= icon('pencil', class: 'size-4') %>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Focusable disabled button" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "aria_disabled: true" } %> when the action is not yet available but the button should
      remain focusable so screen reader users hear validation feedback after activation. The Overview preview compares
      all three states side by side.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <form>
        <%= pathogen_supporting(variant: :muted, class: "mb-4") { "Complete required fields before continuing." } %>

        <div class="flex items-center gap-2">
          <%= render Pathogen::Button.new(tone: :neutral, emphasis: :outline, text: 'Back') %>
          <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, aria_disabled: true, text: 'Continue') %>
        </div>
      </form>
    </div>
  </section>
</div>
