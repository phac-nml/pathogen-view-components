<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Standalone form actions</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      <code class="font-mono">pathogen_button_to</code> mirrors Rails <code class="font-mono">button_to</code> but
      renders <code class="font-mono">Pathogen::Button</code> so form actions match the design system. Prefer
      <code class="font-mono">tone</code> + <code class="font-mono">emphasis</code>; legacy
      <code class="font-mono">scheme</code> remains supported.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <div class="flex flex-wrap items-center gap-2">
        <%= pathogen_button_to "Retry analysis", "#", method: :post, tone: :primary, emphasis: :solid %>
        <%= pathogen_button_to "Cancel", "#", method: :post, tone: :neutral, emphasis: :outline %>
        <%= pathogen_button_to "Reset", "#", method: :post, tone: :neutral, emphasis: :ghost %>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Destructive actions</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Use <code class="font-mono">danger + outline</code> for available destructive actions, and reserve
      <code class="font-mono">danger + solid</code> for explicit confirmation steps.
    </p>

    <div class="flex flex-col gap-4">
      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <div class="flex flex-wrap items-center gap-2">
          <%= pathogen_button_to "Delete specimen", "#", method: :delete, tone: :danger, emphasis: :outline,
                data: { turbo_confirm: "Delete this record?" } %>

          <%= pathogen_button_to "Archive", "#", method: :post, tone: :neutral, emphasis: :outline %>
        </div>
      </div>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <p class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Confirm delete</p>

        <div class="flex flex-wrap items-center gap-2">
          <%= pathogen_button_to "Delete permanently", "#", method: :delete, tone: :danger, emphasis: :solid,
                data: { turbo_confirm: "This cannot be undone. Delete permanently?" } %>

          <%= pathogen_button_to "Keep record", "#", method: :post, tone: :neutral, emphasis: :outline %>
        </div>
      </div>
    </div>
  </section>
</div>
