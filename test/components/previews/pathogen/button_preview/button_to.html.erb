<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Standalone form actions" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      <%= pathogen_code { "pathogen_button_to" } %> mirrors Rails <%= pathogen_code { "button_to" } %> but renders
      <%= pathogen_code { "Pathogen::Button" } %> so form actions match the design system. Use
      <%= pathogen_code { "tone" } %> + <%= pathogen_code { "emphasis" } %> to style submit actions.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <div class="flex flex-wrap items-center gap-2">
        <%= pathogen_button_to "Retry analysis", "#", method: :post, tone: :primary, emphasis: :solid %>
        <%= pathogen_button_to "Cancel", "#", method: :post, tone: :neutral, emphasis: :outline %>
        <%= pathogen_button_to "Reset", "#", method: :post, tone: :neutral, emphasis: :ghost %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Destructive actions" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "danger + outline" } %> for available destructive actions, and reserve
      <%= pathogen_code { "danger + solid" } %> for explicit confirmation steps.
    <% end %>

    <div class="flex flex-col gap-4">
      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <div class="flex flex-wrap items-center gap-2">
          <%= pathogen_button_to "Delete specimen", "#", method: :delete, tone: :danger, emphasis: :outline,
                data: { turbo_confirm: "Delete this record?" } %>

          <%= pathogen_button_to "Archive", "#", method: :post, tone: :neutral, emphasis: :outline %>
        </div>
      </div>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <%= pathogen_heading(level: 5, class: "mb-3 font-semibold") { "Confirm delete" } %>

        <div class="flex flex-wrap items-center gap-2">
          <%= pathogen_button_to "Delete permanently", "#", method: :delete, tone: :danger, emphasis: :solid,
                data: { turbo_confirm: "This cannot be undone. Delete permanently?" } %>

          <%= pathogen_button_to "Keep record", "#", method: :post, tone: :neutral, emphasis: :outline %>
        </div>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Detached actions" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Pass <%= pathogen_code { "detached: true" } %> when the button needs to sit outside its generated form, such
      as a table action cell or menu item. The helper renders a hidden sibling form plus a standalone button linked
      back to it through the HTML <%= pathogen_code { "form" } %> attribute, keeping full Rails form semantics.
    <% end %>

    <div class="overflow-hidden rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]">
      <table class="w-full text-left text-sm">
        <thead class="sr-only">
          <tr>
            <th scope="col">Sample ID</th>
            <th scope="col">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% ["specimen-001", "specimen-002"].each do |sample| %>
            <tr class="border-b border-[var(--pvc-color-border)] last:border-0">
              <td class="px-4 py-3"><%= sample %></td>

              <td class="px-4 py-3">
                <div class="flex justify-end gap-2">
                  <%= pathogen_button_to "Edit", "#", method: :get, detached: true, tone: :neutral, emphasis: :ghost %>

                  <%= pathogen_button_to "Delete", "#", method: :delete, detached: true, tone: :danger,
                        emphasis: :outline, data: { turbo_confirm: "Delete #{sample}?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
