<%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
  <fieldset class="space-y-4">
    <legend class="mb-3 text-sm font-semibold text-neutral-900 dark:text-neutral-100">Export options</legend>

    <div class="flex items-start gap-3">
      <%= f.check_box :include_metadata, { checked: true }, "1", "0" %>

      <div class="min-w-0">
        <%= f.label :include_metadata, "Include metadata", class: "mb-1" %>

        <p class="m-0 text-sm leading-[1.45] text-neutral-600 dark:text-neutral-400">
          Add sample, project, and collection fields to the export.
        </p>
      </div>
    </div>

    <div class="flex items-start gap-3">
      <%= f.check_box :include_analysis, {}, "1", "0" %>

      <div class="min-w-0">
        <%= f.label :include_analysis, "Include analysis results", class: "mb-1" %>
      </div>
    </div>
  </fieldset>
<% end %>
