<%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
  <div class="flex items-start gap-3">
    <%= f.check_box :archive_samples, { checked: checked, disabled: disabled }, "1", "0" %>

    <div class="min-w-0">
      <%= f.label :archive_samples, "Archive samples", class: "mb-1" %>

      <p class="m-0 text-sm leading-[1.45] text-neutral-600 dark:text-neutral-400">
        Keep selected samples available in long-term storage.
      </p>
    </div>
  </div>
<% end %>
