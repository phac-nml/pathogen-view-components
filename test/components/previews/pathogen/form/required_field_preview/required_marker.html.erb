<div style="max-width: 320px; padding: 1.5rem; font-family: system-ui, sans-serif;">
  <div style="display: flex; flex-direction: column; gap: 0.375rem;">
    <label for="required-field-email" style="font-size: 0.875rem; font-weight: 500; color: #374151; display: flex; align-items: center; gap: 0.25rem;">
      Email
      <abbr class="req" title="required" aria-hidden="true" style="color: #dc2626; text-decoration: none; font-weight: 600;">*</abbr>
    </label>
    <input id="required-field-email" type="email" autocomplete="email"
      style="border: 1px solid #d1d5db; border-radius: 0.375rem; padding: 0.5rem 0.75rem; font-size: 0.875rem; color: #111827; outline: none; width: 100%; box-sizing: border-box;"
      placeholder="you@example.com">
  </div>
</div>

<div style="max-width: 320px; padding: 1.5rem; font-family: system-ui, sans-serif; background: #111827; border-radius: 0.5rem; margin-top: 1rem;">
  <div style="display: flex; flex-direction: column; gap: 0.375rem;">
    <label for="required-field-email-dark" style="font-size: 0.875rem; font-weight: 500; color: #d1d5db; display: flex; align-items: center; gap: 0.25rem;">
      Email
      <abbr class="req" title="required" aria-hidden="true" style="color: #f87171; text-decoration: none; font-weight: 600;">*</abbr>
    </label>
    <input id="required-field-email-dark" type="email" autocomplete="email"
      style="border: 1px solid #374151; border-radius: 0.375rem; padding: 0.5rem 0.75rem; font-size: 0.875rem; color: #f9fafb; background: #1f2937; outline: none; width: 100%; box-sizing: border-box;"
      placeholder="you@example.com">
  </div>
</div>
