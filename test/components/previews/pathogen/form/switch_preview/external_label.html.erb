<% switch_id = "feature-v2-samplesheet-switch" %>
<% label_id = "feature-v2-samplesheet-label" %>
<% description_id = "feature-v2-samplesheet-description" %>

<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
  <div class="min-w-0 flex-1">
    <%= label_tag switch_id, "V2 Samplesheet", id: label_id,
          class: "cursor-pointer text-sm font-semibold text-neutral-800 dark:text-white" %>

    <p id="<%= description_id %>" class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
      Try the redesigned samplesheet experience.
    </p>
  </div>

  <%= render Pathogen::Form::Switch.new(
    form: form,
    attribute: :v2_samplesheet,
    id: switch_id,
    checked: true,
    aria: { labelledby: label_id, describedby: description_id }
  ) %>
</div>
