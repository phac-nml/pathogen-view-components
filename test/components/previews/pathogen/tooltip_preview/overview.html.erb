<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Placement" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Tooltips attach to a trigger via <%= pathogen_code { "with_tooltip" } %> on
      <%= pathogen_code { "Pathogen::Link" } %> or <%= pathogen_code { "Pathogen::Button" } %>. Default placement is
      <%= pathogen_code { ":top" } %>. Hover or focus each trigger to inspect position.
    <% end %>

    <div class="overflow-x-auto rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]">
      <table class="w-full min-w-[36rem] border-collapse text-sm">
        <thead>
          <tr class="border-b border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)]">
            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Placement" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "When to use" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Example" } %>
            </th>
          </tr>
        </thead>

        <tbody class="divide-y divide-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
          <% [
            [:top, "Default. Use when space below the trigger is tight.", "View QC summary"],
            [:bottom, "Top navigation, breadcrumbs, and page chrome.", "Open run detail"],
            [:left, "Triggers near the right edge of a panel.", "Export submission"],
            [:right, "Collapsed sidebars and left-edge icon rails.", "Sequencing runs"]
          ].each do |placement, guidance, label| %>
            <tr>
              <td class="px-4 py-3 align-middle">
                <%= pathogen_code(class: "text-xs") { "placement: #{placement.inspect}" } %>
              </td>

              <td class="px-4 py-3 align-middle">
                <%= pathogen_supporting(tag: :span, variant: :muted) { guidance } %>
              </td>

              <td class="px-4 py-3 align-middle">
                <%= render Pathogen::Link.new(href: "#") do |link| %>
                  <% link.with_tooltip(text: label, placement:) %>
                  <%= label %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Text length" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Keep tooltip copy brief. Longer strings wrap inside a <%= pathogen_code { "max-w-xs" } %> (320px) cap so dense
      toolbars stay readable.
    <% end %>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <%= pathogen_supporting(tag: :span, variant: :muted, class: "mb-3 block") { "Short label" } %>

        <%= render Pathogen::Link.new(href: "#") do |link| %>
          <% link.with_tooltip(text: "View specimen metadata") %> SP-2026-0042
        <% end %>
      </div>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <%= pathogen_supporting(tag: :span, variant: :muted, class: "mb-3 block") { "Wrapped copy" } %>

        <%= render Pathogen::Link.new(href: "#") do |link| %>
          <% link.with_tooltip(
            text: "Pipeline v3.2 applies AMR gene detection, MLST typing, and quality trimming before assembly release.",
            placement: :bottom,
          ) %>
          WGS bacterial v3.2
        <% end %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Grid toolbar" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Icon-only controls need distinct tooltip labels. Use <%= pathogen_code { "placement: :top" } %> on row actions so
      labels do not collide with pagination below.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
      <div class="flex items-center justify-between gap-4 border-b border-[var(--pvc-color-border)] px-4 py-3">
        <%= pathogen_heading(level: 5, class: "font-semibold") { "Sequencing submissions" } %>
        <%= pathogen_supporting(tag: :span, variant: :muted) { "48 specimens · 2 need review" } %>
      </div>

      <div class="flex items-center justify-between gap-4 border-b border-[var(--pvc-color-border)] px-4 py-3">
        <div>
          <%= pathogen_supporting(tag: :span, class: "font-semibold text-[var(--pvc-color-text)]") { "RUN-2026-0142" } %>
          <%= pathogen_supporting(tag: :span, variant: :muted, class: "mt-0.5 block") { "Submitted 10 Jun 2026" } %>
        </div>

        <div class="flex items-center gap-2">
          <%= render Pathogen::Link.new(href: "#view", aria: { label: "View run detail" }) do |link| %>
            <% link.with_tooltip(text: "View run detail", placement: :top) %>
            <%= icon("eye", class: "size-4 text-[var(--pvc-color-text-muted)]") %>
          <% end %>

          <%= render Pathogen::Link.new(href: "#download", aria: { label: "Download QC report" }) do |link| %>
            <% link.with_tooltip(text: "Download QC report", placement: :top) %>
            <%= icon("download-simple", class: "size-4 text-[var(--pvc-color-text-muted)]") %>
          <% end %>

          <%= render Pathogen::Link.new(href: "#edit", aria: { label: "Edit run metadata" }) do |link| %>
            <% link.with_tooltip(text: "Edit run metadata", placement: :top) %>
            <%= icon("pencil", class: "size-4 text-[var(--pvc-color-text-muted)]") %>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <div
    class="
      rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4
      text-sm
    "
  >
    <%= pathogen_supporting(tag: :span, class: "font-semibold text-[var(--pvc-color-text)]") { "Usage" } %>

    <%= pathogen_supporting(variant: :muted, class: "mt-2") do %>
      Tooltips supplement visible labels. Do not hide critical workflow steps behind hover-only copy.
    <% end %>
  </div>
</div>
