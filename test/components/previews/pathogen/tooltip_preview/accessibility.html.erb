<%# herb:formatter ignore %>

<div
  class="
    p-6 bg-[var(--pvc-color-surface-muted)]
     min-h-screen
  "
>
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-[length:var(--type-page)] font-bold text-[var(--pvc-color-text)]  mb-4">
      Tooltip Accessibility &amp; Keyboard Navigation
    </h1>

    <p class="text-lg text-[var(--pvc-color-text-muted)] max-w-3xl">
      Demonstrating ARIA compliance, keyboard accessibility, and screen reader support
    </p>
  </div>

  <!-- Hover & Focus Triggers -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)]  mb-6 flex items-center">
      Dual Trigger Mechanism
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border border-[var(--pvc-color-border)]
         p-6
      "
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Hover Trigger -->
        <div>
          <h3 class="text-lg font-semibold text-[var(--pvc-color-text)]  mb-4 flex items-center">
            Mouse Hover
          </h3>

          <p class="text-[var(--pvc-color-text-muted)] mb-4">
            Tooltips appear when you hover over the trigger element with your mouse.
          </p>

          <div class="p-6 bg-[var(--pvc-color-surface-muted)]  rounded-[var(--pvc-radius-panel)] text-center">
            <%= render Pathogen::Link.new(href: "#") do |link| %>
              <% link.with_tooltip(text: "I appear on mouse hover!", placement: :top) %> Hover over me
            <% end %>
          </div>
        </div>

        <!-- Focus Trigger -->
        <div>
          <h3 class="text-lg font-semibold text-[var(--pvc-color-text)]  mb-4 flex items-center">
            Keyboard Focus
          </h3>

          <p class="text-[var(--pvc-color-text-muted)] mb-4">
            Tooltips also appear when you focus the element using Tab key navigation.
          </p>

          <div class="p-6 bg-[var(--pvc-color-surface-muted)]  rounded-[var(--pvc-radius-panel)] text-center">
            <%= render Pathogen::Link.new(href: "#") do |link| %>
              <% link.with_tooltip(text: "I appear on keyboard focus!", placement: :top) %> Tab to focus me
            <% end %>
          </div>
        </div>
      </div>

      <div
        class="
          mt-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200
          dark:border-blue-800 rounded-[var(--pvc-radius-panel)]
        "
      >
        <div class="flex items-start gap-3">
          <div class="text-sm">
            <p class="font-semibold text-blue-900 dark:text-blue-100 mb-1">
              Why Both Triggers?
            </p>

            <p class="text-blue-800 dark:text-blue-200">
              Supporting both hover and focus ensures the tooltip is accessible to all users: mouse users see it on
              hover, while keyboard and screen reader users see it on focus.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ARIA Attributes -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)]  mb-6 flex items-center">
      ARIA Compliance
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border border-[var(--pvc-color-border)]
         p-6
      "
    >
      <p class="text-[var(--pvc-color-text-muted)] mb-6">
        Tooltips follow W3C ARIA best practices to ensure screen reader compatibility:
      </p>

      <div class="space-y-6">
        <!-- role="tooltip" -->
        <div class="flex items-start gap-4">

          <div class="flex-1">
            <h3 class="font-semibold text-[var(--pvc-color-text)]  mb-2">
              <code class="text-sm bg-[var(--pvc-color-surface-muted)]  px-2 py-1 rounded"> role="tooltip" </code>
            </h3>

            <p class="text-[var(--pvc-color-text-muted)]">
              The tooltip element has <code>role="tooltip"</code> to inform screen readers that this is supplementary
              information.
            </p>
          </div>
        </div>

        <!-- aria-describedby -->
        <div class="flex items-start gap-4">

          <div class="flex-1">
            <h3 class="font-semibold text-[var(--pvc-color-text)]  mb-2">
              <code class="text-sm bg-[var(--pvc-color-surface-muted)]  px-2 py-1 rounded"> aria-describedby </code>
            </h3>

            <p class="text-[var(--pvc-color-text-muted)]">
              The trigger element references the tooltip via <code>aria-describedby</code>, creating an accessible
              relationship between them. Screen readers announce the tooltip content when the trigger receives focus.
            </p>
          </div>
        </div>

        <!-- Unique IDs -->
        <div class="flex items-start gap-4">

          <div class="flex-1">
            <h3 class="font-semibold text-[var(--pvc-color-text)]  mb-2">
              Unique Tooltip IDs
            </h3>

            <p class="text-[var(--pvc-color-text-muted)]">
              Each tooltip is automatically assigned a unique ID to ensure proper ARIA connections and avoid conflicts.
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          mt-8 bg-[var(--pvc-color-surface-muted)]  border border-[var(--pvc-color-border)]
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <p class="text-sm font-semibold text-[var(--pvc-color-text)]  mb-2">
          Example HTML Structure:
        </p>

        <pre class="text-xs overflow-x-auto"><code class="text-[var(--pvc-color-text-muted)] ">&lt;a href="/samples" aria-describedby="tooltip-abc123"
            data-pathogen--tooltip-target="trigger"&gt; Samples &lt;/a&gt;
            &lt;div id="tooltip-abc123" role="tooltip"
            data-pathogen--tooltip-target="tooltip"&gt; View all samples
            &lt;/div&gt;
                                          </code></pre>
      </div>
    </div>
  </div>

  <!-- Keyboard Navigation Demo -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)]  mb-6 flex items-center">
      Keyboard Navigation Demo
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border border-[var(--pvc-color-border)]
         p-6
      "
    >
      <p class="text-[var(--pvc-color-text-muted)] mb-6">
        Use the <kbd class="px-2 py-1 bg-[var(--pvc-color-border)] rounded text-sm font-mono">Tab</kbd> key to
        navigate through these links. The tooltip will appear when each link receives focus.
      </p>

      <div class="flex flex-wrap gap-4 p-6 bg-[var(--pvc-color-surface-muted)]  rounded-[var(--pvc-radius-panel)]">
        <%= render Pathogen::Link.new(href: "#first") do |link| %>
          <% link.with_tooltip(text: "First link in the sequence", placement: :top) %> First Link
        <% end %>

        <%= render Pathogen::Link.new(href: "#second") do |link| %>
          <% link.with_tooltip(text: "Second link in the sequence", placement: :top) %> Second Link
        <% end %>

        <%= render Pathogen::Link.new(href: "#third") do |link| %>
          <% link.with_tooltip(text: "Third link in the sequence", placement: :top) %> Third Link
        <% end %>

        <%= render Pathogen::Link.new(href: "#fourth") do |link| %>
          <% link.with_tooltip(text: "Fourth link in the sequence", placement: :top) %> Fourth Link
        <% end %>
      </div>

      <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div
          class="
            p-4 bg-green-50 dark:bg-green-900/20 border border-green-200
            dark:border-green-800 rounded-[var(--pvc-radius-panel)]
          "
        >
          <div class="flex items-center gap-2 mb-2">
            <kbd class="px-2 py-1 bg-green-200 dark:bg-green-800 rounded text-sm font-mono"> Tab </kbd>

            <span class="text-green-900 dark:text-green-100 font-semibold"> Move Forward </span>
          </div>

          <p class="text-sm text-green-800 dark:text-green-200">
            Press Tab to move to the next focusable element
          </p>
        </div>

        <div
          class="
            p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800
            rounded-[var(--pvc-radius-panel)]
          "
        >
          <div class="flex items-center gap-2 mb-2">
            <kbd class="px-2 py-1 bg-blue-200 dark:bg-blue-800 rounded text-sm font-mono"> Shift+Tab </kbd>

            <span class="text-blue-900 dark:text-blue-100 font-semibold"> Move Backward </span>
          </div>

          <p class="text-sm text-blue-800 dark:text-blue-200">
            Press Shift+Tab to move to the previous element
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Best Practices -->
  <div>
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)]  mb-6 flex items-center">
      Accessibility Best Practices
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div
        class="
          bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <div>
            <h3 class="font-semibold text-green-900 dark:text-green-100 mb-1">
              Keep Text Concise
            </h3>

            <p class="text-sm text-green-800 dark:text-green-200">
              Tooltips should provide brief, supplementary information. Avoid lengthy descriptions.
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <div>
            <h3 class="font-semibold text-green-900 dark:text-green-100 mb-1">
              Supplement, Don't Replace
            </h3>

            <p class="text-sm text-green-800 dark:text-green-200">
              Tooltips should enhance understanding, not be the sole source of critical information.
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <div>
            <h3 class="font-semibold text-green-900 dark:text-green-100 mb-1">
              Keyboard Accessible
            </h3>

            <p class="text-sm text-green-800 dark:text-green-200">
              Always ensure tooltips appear on focus, not just hover, for keyboard users.
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <div>
            <h3 class="font-semibold text-green-900 dark:text-green-100 mb-1">
              Screen Reader Friendly
            </h3>

            <p class="text-sm text-green-800 dark:text-green-200">
              Proper ARIA attributes ensure screen readers announce tooltip content naturally.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
