<div class="p-6 bg-[var(--pvc-color-surface-muted)] min-h-screen">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-[length:var(--type-page)] font-bold text-[var(--pvc-color-text)] mb-4">
      Pathogen Tooltip - Basic Usage
    </h1>

    <p class="text-lg text-[var(--pvc-color-text-muted)] max-w-3xl">
      Accessible tooltips for compact clinical interfaces, with keyboard and pointer support.
    </p>
  </div>

  <!-- Four Placement Options -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Four Placement Options
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border border-[var(--pvc-color-border)]
        p-6
      "
    >
      <div class="flex flex-col items-center justify-center space-y-24">
        <!-- Top Placement -->
        <div class="text-center">
          <p class="text-sm text-[var(--pvc-color-text-muted)] mb-4">Top Placement (Default)</p>

          <%= render Pathogen::Link.new(href: "#") do |link| %>
            <% link.with_tooltip(text: "This tooltip appears above the link", placement: :top) %> Hover or focus me
            (top)
          <% end %>
        </div>

        <div class="flex items-center justify-center space-x-48">
          <!-- Left Placement -->
          <div class="text-center">
            <p class="text-sm text-[var(--pvc-color-text-muted)] mb-4">Left Placement</p>

            <%= render Pathogen::Link.new(href: "#") do |link| %>
              <% link.with_tooltip(text: "This tooltip appears to the left", placement: :left) %> Hover or focus me
              (left)
            <% end %>
          </div>

          <!-- Right Placement -->
          <div class="text-center">
            <p class="text-sm text-[var(--pvc-color-text-muted)] mb-4">Right Placement</p>

            <%= render Pathogen::Link.new(href: "#") do |link| %>
              <% link.with_tooltip(text: "This tooltip appears to the right", placement: :right) %> Hover or focus me
              (right)
            <% end %>
          </div>
        </div>

        <!-- Bottom Placement -->
        <div class="text-center">
          <p class="text-sm text-[var(--pvc-color-text-muted)] mb-4">Bottom Placement</p>

          <%= render Pathogen::Link.new(href: "#") do |link| %>
            <% link.with_tooltip(
              text: "This tooltip appears below the link",
              placement: :bottom,
            ) %>
            Hover or focus me (bottom)
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Simple Examples -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Simple Examples
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Example 1: Default Tooltip -->
      <div
        class="
          bg-[var(--pvc-color-surface)] rounded-[var(--pvc-radius-panel)] p-6 border
          border-[var(--pvc-color-border)]
        "
      >
        <h3 class="text-lg font-semibold text-[var(--pvc-color-text)] mb-4">Default Tooltip</h3>

        <div class="p-4 bg-[var(--pvc-color-surface-muted)] rounded">
          <%= render Pathogen::Link.new(href: "/samples") do |link| %>
            <% link.with_tooltip(text: "View all samples") %> Samples
          <% end %>
        </div>
      </div>

      <!-- Example 2: Bottom Placement -->
      <div
        class="
          bg-[var(--pvc-color-surface)] rounded-[var(--pvc-radius-panel)] p-6 border
          border-[var(--pvc-color-border)]
        "
      >
        <h3 class="text-lg font-semibold text-[var(--pvc-color-text)] mb-4">Custom Placement</h3>

        <div class="p-4 bg-[var(--pvc-color-surface-muted)] rounded">
          <%= render Pathogen::Link.new(href: "/projects") do |link| %>
            <% link.with_tooltip(text: "Manage your projects", placement: :bottom) %> Projects
          <% end %>
        </div>
      </div>

      <!-- Example 3: Left Placement -->
      <div
        class="
          bg-[var(--pvc-color-surface)] rounded-[var(--pvc-radius-panel)] p-6 border
          border-[var(--pvc-color-border)]
        "
      >
        <h3 class="text-lg font-semibold text-[var(--pvc-color-text)] mb-4">Left Placement</h3>

        <div class="p-4 bg-[var(--pvc-color-surface-muted)] rounded">
          <%= render Pathogen::Link.new(href: "/settings") do |link| %>
            <% link.with_tooltip(text: "Configure application settings", placement: :left) %> Settings
          <% end %>
        </div>
      </div>

      <!-- Example 4: Right Placement -->
      <div
        class="
          bg-[var(--pvc-color-surface)] rounded-[var(--pvc-radius-panel)] p-6 border
          border-[var(--pvc-color-border)]
        "
      >
        <h3 class="text-lg font-semibold text-[var(--pvc-color-text)] mb-4">Right Placement</h3>

        <div class="p-4 bg-[var(--pvc-color-surface-muted)] rounded">
          <%= render Pathogen::Link.new(href: "/help") do |link| %>
            <% link.with_tooltip(text: "Get help and documentation", placement: :right) %> Help
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Parameter Reference -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Component Parameters
    </h2>

    <div class="bg-[var(--pvc-color-surface)] rounded-[var(--pvc-radius-panel)] p-6 border border-[var(--pvc-color-border)]">
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-[var(--pvc-color-border)]">
              <th class="py-3 px-4 font-semibold text-[var(--pvc-color-text)]">Parameter</th>
              <th class="py-3 px-4 font-semibold text-[var(--pvc-color-text)]">Type</th>
              <th class="py-3 px-4 font-semibold text-[var(--pvc-color-text)]">Required</th>
              <th class="py-3 px-4 font-semibold text-[var(--pvc-color-text)]">Description</th>
            </tr>
          </thead>

          <tbody class="text-sm">
            <tr class="border-b border-[var(--pvc-color-border)]">
              <td class="py-3 px-4 font-mono text-blue-600 dark:text-blue-400">text</td>
              <td class="py-3 px-4 text-[var(--pvc-color-text-muted)]">String</td>

              <td class="py-3 px-4">
                <span
                  class="
                    px-2 py-1 bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200 rounded
                    text-xs
                  "
                >
                  Required
                </span>
              </td>

              <td class="py-3 px-4 text-[var(--pvc-color-text-muted)]">The tooltip text content</td>
            </tr>

            <tr class="border-b border-[var(--pvc-color-border)]">
              <td class="py-3 px-4 font-mono text-blue-600 dark:text-blue-400">placement</td>
              <td class="py-3 px-4 text-[var(--pvc-color-text-muted)]">Symbol</td>

              <td class="py-3 px-4">
                <span
                  class="
                    px-2 py-1 bg-[var(--pvc-color-surface-muted)] text-[var(--pvc-color-text-muted)]
                    rounded text-xs
                  "
                >
                  Optional
                </span>
              </td>

              <td class="py-3 px-4 text-[var(--pvc-color-text-muted)]">
                Position: :top (default), :bottom, :left, :right
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Quick Tips -->
  <div>
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Quick Tips
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div
        class="
          bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('info', class: "w-5 h-5 flex-shrink-0 text-blue-500 dark:text-blue-400") %>

          <div>
            <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-1">Default Placement is Top</h3>

            <p class="text-sm text-blue-800 dark:text-blue-200">
              If you don't specify a placement, tooltips will appear above the trigger element
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('check-circle', class: "w-5 h-5 flex-shrink-0 text-green-500 dark:text-green-400") %>

          <div>
            <h3 class="font-semibold text-green-900 dark:text-green-100 mb-1">Automatic Sizing</h3>

            <p class="text-sm text-green-800 dark:text-green-200">
              Tooltips automatically size to fit content with a max width of 320px
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-[var(--pvc-color-surface-muted)]  border border-[var(--pvc-color-border)]
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('lightning', class: "w-5 h-5 flex-shrink-0 text-amber-500 dark:text-amber-400") %>

          <div>
            <h3 class="font-semibold text-[var(--pvc-color-text)] mb-1">Smooth Animations</h3>

            <p class="text-sm text-[var(--pvc-color-text)]">
              200ms fade-in and scale animation for a polished feel
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('warning', class: "w-5 h-5 flex-shrink-0 text-amber-500 dark:text-amber-400") %>

          <div>
            <h3 class="font-semibold text-amber-900 dark:text-amber-100 mb-1">Lightweight Dependencies</h3>

            <p class="text-sm text-amber-800 dark:text-amber-200">
              Uses Floating UI for precise positioning instead of Flowbite/Popper.js
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
