<div class="p-6 bg-[var(--pvc-color-surface-muted)] min-h-screen">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-[length:var(--type-page)] font-bold text-[var(--pvc-color-text)] mb-4">
      Link Component Integration
    </h1>

    <p class="text-lg text-[var(--pvc-color-text-muted)] max-w-3xl">
      Tooltip patterns for project navigation, sample actions, breadcrumbs, and compact sidebars
    </p>
  </div>

  <!-- Navigation Bar Example -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Navigation Bar with Tooltips
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border
        border-[var(--pvc-color-border)]  overflow-hidden
      "
    >
      <nav class="flex items-center justify-between p-4 border-b border-[var(--pvc-color-border)]">
        <div class="flex items-center space-x-6">
          <%= render Pathogen::Link.new(href: "/dashboard") do |link| %>
            <% link.with_tooltip(text: "View your dashboard", placement: :bottom) %>
            <%= icon('house', class: "text-[var(--pvc-color-text-muted)] w-5 h-5 flex-shrink-0 inline mr-2") %>
            Dashboard
          <% end %>

          <%= render Pathogen::Link.new(href: "/samples") do |link| %>
            <% link.with_tooltip(text: "Browse and manage samples", placement: :bottom) %>
            <%= icon('flask', class: "text-[var(--pvc-color-text-muted)] w-5 h-5 flex-shrink-0 inline mr-2") %> Samples
          <% end %>

          <%= render Pathogen::Link.new(href: "/projects") do |link| %>
            <% link.with_tooltip(text: "View all projects", placement: :bottom) %>
            <%= icon('folder', class: "text-[var(--pvc-color-text-muted)] w-5 h-5 flex-shrink-0 inline mr-2") %>
            Projects
          <% end %>

          <%= render Pathogen::Link.new(href: "/workflows") do |link| %>
            <% link.with_tooltip(text: "Manage analysis workflows", placement: :bottom) %>
            <%= icon('play', class: "text-[var(--pvc-color-text-muted)] w-5 h-5 flex-shrink-0 inline mr-2") %> Workflows
          <% end %>
        </div>

        <div class="flex items-center space-x-4">
          <%= render Pathogen::Link.new(href: "/settings") do |link| %>
            <% link.with_tooltip(text: "Configure settings", placement: :bottom) %>
            <%= icon('gear', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
          <% end %>

          <%= render Pathogen::Link.new(href: "/help") do |link| %>
            <% link.with_tooltip(text: "Get help and documentation", placement: :bottom) %>
            <%= icon('question', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
          <% end %>
        </div>
      </nav>

      <div class="p-6">
        <p class="text-sm text-[var(--pvc-color-text-muted)]">
          This navigation bar uses tooltips with bottom placement to provide helpful context for each link.
        </p>
      </div>
    </div>
  </div>

  <!-- Action List Example -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Action List with Contextual Tooltips
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border
        border-[var(--pvc-color-border)]  p-6
      "
    >
      <div class="space-y-4">
        <div
          class="
            flex items-center justify-between p-4 bg-[var(--pvc-color-surface-muted)]
            rounded-[var(--pvc-radius-panel)]
          "
        >
          <div>
            <h3 class="font-semibold text-[var(--pvc-color-text)]">
              Sample-001
            </h3>

            <p class="text-sm text-[var(--pvc-color-text-muted)]">
              Collected: 2024-01-15
            </p>
          </div>

          <div class="flex items-center space-x-3">
            <%= render Pathogen::Link.new(href: "/samples/1/view") do |link| %>
              <% link.with_tooltip(text: "View sample details", placement: :top) %>
              <%= icon('eye', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/samples/1/edit") do |link| %>
              <% link.with_tooltip(text: "Edit sample metadata", placement: :top) %>
              <%= icon('pencil', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/samples/1/download") do |link| %>
              <% link.with_tooltip(text: "Download sample files", placement: :top) %>
              <%= icon('download', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>
          </div>
        </div>

        <div
          class="
            flex items-center justify-between p-4 bg-[var(--pvc-color-surface-muted)]
            rounded-[var(--pvc-radius-panel)]
          "
        >
          <div>
            <h3 class="font-semibold text-[var(--pvc-color-text)]">
              Sample-002
            </h3>

            <p class="text-sm text-[var(--pvc-color-text-muted)]">
              Collected: 2024-01-16
            </p>
          </div>

          <div class="flex items-center space-x-3">
            <%= render Pathogen::Link.new(href: "/samples/2/view") do |link| %>
              <% link.with_tooltip(text: "View sample details", placement: :top) %>
              <%= icon('eye', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/samples/2/edit") do |link| %>
              <% link.with_tooltip(text: "Edit sample metadata", placement: :top) %>
              <%= icon('pencil', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/samples/2/download") do |link| %>
              <% link.with_tooltip(text: "Download sample files", placement: :top) %>
              <%= icon('download', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>
          </div>
        </div>
      </div>

      <div
        class="
          mt-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200
          dark:border-blue-800 rounded-[var(--pvc-radius-panel)]
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('info', class: "w-5 h-5 flex-shrink-0 text-blue-500 dark:text-blue-400") %>

          <div class="text-sm">
            <p class="font-semibold text-blue-900 dark:text-blue-100 mb-1">
              Icon-Only Actions
            </p>

            <p class="text-blue-800 dark:text-blue-200">
              Tooltips are especially useful for icon-only action buttons, providing context without cluttering the
              interface.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Breadcrumb Example -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Breadcrumb Navigation
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border
        border-[var(--pvc-color-border)]  p-6
      "
    >
      <nav class="flex items-center space-x-2 text-sm">
        <%= render Pathogen::Link.new(href: "/") do |link| %>
          <% link.with_tooltip(text: "Go to home page", placement: :bottom) %>
          <%= icon('house', class: "text-[var(--pvc-color-text-muted)] w-5 h-5 flex-shrink-0 inline") %>
        <% end %>

        <span class="text-[var(--pvc-color-text-muted)]">/</span>

        <%= render Pathogen::Link.new(href: "/projects") do |link| %>
          <% link.with_tooltip(text: "View all projects", placement: :bottom) %> Projects
        <% end %>

        <span class="text-[var(--pvc-color-text-muted)]">/</span>

        <%= render Pathogen::Link.new(href: "/projects/irida-next") do |link| %>
          <% link.with_tooltip(text: "View project details", placement: :bottom) %> IRIDA Next
        <% end %>

        <span class="text-[var(--pvc-color-text-muted)]">/</span>

        <span class="text-[var(--pvc-color-text-muted)]">Samples</span>
      </nav>

      <div
        class="
          mt-6 p-4 bg-[var(--pvc-color-surface-muted)]  border
          border-[var(--pvc-color-border)]  rounded-[var(--pvc-radius-panel)]
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('info', class: "w-5 h-5 flex-shrink-0 text-blue-500 dark:text-blue-400") %>

          <div class="text-sm">
            <p class="font-semibold text-[var(--pvc-color-text)] mb-1">
              Breadcrumb Tooltips
            </p>

            <p class="text-[var(--pvc-color-text)]">
              Tooltips in breadcrumbs help users understand where each link will take them, improving navigation
              confidence.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sidebar Menu Example -->
  <div class="mb-8">
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Collapsed Sidebar with Tooltips
    </h2>

    <div
      class="
        bg-[var(--pvc-color-surface)]  rounded-[var(--pvc-radius-panel)]  border
        border-[var(--pvc-color-border)]  overflow-hidden
      "
    >
      <div class="flex">
        <!-- Collapsed Sidebar -->
        <aside class="w-16 bg-[var(--pvc-color-surface-muted)] border-r border-[var(--pvc-color-border)]">
          <nav class="flex flex-col items-center py-4 space-y-4">
            <%= render Pathogen::Link.new(href: "/dashboard") do |link| %>
              <% link.with_tooltip(text: "Dashboard", placement: :right) %>
              <%= icon('house', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/samples") do |link| %>
              <% link.with_tooltip(text: "Samples", placement: :right) %>
              <%= icon('flask', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/projects") do |link| %>
              <% link.with_tooltip(text: "Projects", placement: :right) %>
              <%= icon('folder', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/workflows") do |link| %>
              <% link.with_tooltip(text: "Workflows", placement: :right) %>
              <%= icon('play', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "/settings") do |link| %>
              <% link.with_tooltip(text: "Settings", placement: :right) %>
              <%= icon('gear', class: "w-5 h-5 flex-shrink-0 text-[var(--pvc-color-text-muted)]") %>
            <% end %>
          </nav>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 p-6">
          <p class="text-sm text-[var(--pvc-color-text-muted)]">
            In collapsed sidebars, tooltips are essential for identifying icon-only navigation items. Hover or focus on
            each icon to see its label.
          </p>
        </main>
      </div>
    </div>
  </div>

  <!-- Usage Tips -->
  <div>
    <h2 class="text-[length:var(--type-title)] font-semibold text-[var(--pvc-color-text)] mb-6 flex items-center">
      Integration Tips
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div
        class="
          bg-blue-50 dark:bg-blue-900/20 border border-blue-200
          dark:border-blue-800 rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('info', class: "w-5 h-5 flex-shrink-0 text-blue-500 dark:text-blue-400") %>

          <div>
            <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-1">
              Choose Placement Wisely
            </h3>

            <p class="text-sm text-blue-800 dark:text-blue-200">
              Consider the layout: bottom for top navigation, top for footer links, right for left sidebars.
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-green-50 dark:bg-green-900/20 border border-green-200
          dark:border-green-800 rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('check-circle', class: "w-5 h-5 flex-shrink-0 text-green-500 dark:text-green-400") %>

          <div>
            <h3 class="font-semibold text-green-900 dark:text-green-100 mb-1">
              Icon-Only Buttons
            </h3>

            <p class="text-sm text-green-800 dark:text-green-200">
              Always provide tooltips for icon-only actions to ensure clarity for all users.
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-[var(--pvc-color-surface-muted)]  border border-[var(--pvc-color-border)]
          rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('lightning', class: "w-5 h-5 flex-shrink-0 text-amber-500 dark:text-amber-400") %>

          <div>
            <h3 class="font-semibold text-[var(--pvc-color-text)] mb-1">
              Consistent Placement
            </h3>

            <p class="text-sm text-[var(--pvc-color-text)]">
              Use consistent tooltip placement within the same UI section for a cohesive experience.
            </p>
          </div>
        </div>
      </div>

      <div
        class="
          bg-amber-50 dark:bg-amber-900/20 border border-amber-200
          dark:border-amber-800 rounded-[var(--pvc-radius-panel)] p-4
        "
      >
        <div class="flex items-start gap-3">
          <%= icon('warning', class: "w-5 h-5 flex-shrink-0 text-amber-500 dark:text-amber-400") %>

          <div>
            <h3 class="font-semibold text-amber-900 dark:text-amber-100 mb-1">
              Don't Overuse
            </h3>

            <p class="text-sm text-amber-800 dark:text-amber-200">
              Only add tooltips where they provide genuine value. Too many can be overwhelming.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
