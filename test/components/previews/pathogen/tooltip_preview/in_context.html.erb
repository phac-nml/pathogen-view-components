<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Specimen row actions" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Icon-only row utilities need an accessible name via <%= pathogen_code { "aria: { label: ... }" } %> and can use
      tooltips for supplementary detail. Keep labels specific to the row action, not the icon shape.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
      <% [
        ["SP-2026-0042", "Collected 12 Mar 2026", "View specimen detail", "Edit collection metadata", "Download FASTQ files"],
        ["SP-2026-0043", "Collected 13 Mar 2026", "View specimen detail", "Edit collection metadata", "Download FASTQ files"]
      ].each_with_index do |(id, collected, view_label, edit_label, download_label), index| %>
        <div class="<%= index.positive? ? "border-t border-[var(--pvc-color-border)]" : "" %> flex items-center justify-between gap-4 px-4 py-3">
          <div>
            <%= pathogen_supporting(tag: :span, class: "font-semibold text-[var(--pvc-color-text)]") { id } %>
            <%= pathogen_supporting(tag: :span, variant: :muted, class: "mt-0.5 block") { collected } %>
          </div>

          <div class="flex items-center gap-2">
            <%= render Pathogen::Link.new(href: "#view", aria: { label: view_label }) do |link| %>
              <% link.with_tooltip(text: view_label, placement: :top) %>
              <%= icon("eye", class: "size-4 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "#edit", aria: { label: edit_label }) do |link| %>
              <% link.with_tooltip(text: edit_label, placement: :top) %>
              <%= icon("pencil", class: "size-4 text-[var(--pvc-color-text-muted)]") %>
            <% end %>

            <%= render Pathogen::Link.new(href: "#download", aria: { label: download_label }) do |link| %>
              <% link.with_tooltip(text: download_label, placement: :top) %>
              <%= icon("download-simple", class: "size-4 text-[var(--pvc-color-text-muted)]") %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Collapsed sidebar" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      When navigation collapses to icons, use <%= pathogen_code { "placement: :right" } %> so labels open into the
      content area.
    <% end %>

    <div
      class="
        overflow-hidden rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)]
      "
    >
      <div class="flex">
        <aside
          class="
            flex w-14 flex-col items-center gap-2 border-r border-[var(--pvc-color-border)]
            bg-[var(--pvc-color-surface-muted)] py-4
          "
        >
          <% [
            ["house", "Dashboard", "/dashboard"],
            ["flask", "Specimens", "/specimens"],
            ["folder", "Projects", "/projects"],
            ["play", "Workflows", "/workflows"],
            ["gear", "Settings", "/settings"]
          ].each do |icon_name, label, href| %>
            <%= render Pathogen::Link.new(href:, aria: { label: label }) do |link| %>
              <% link.with_tooltip(text: label, placement: :right) %>
              <%= icon(icon_name, class: "size-4 text-[var(--pvc-color-text-muted)]") %>
            <% end %>
          <% end %>
        </aside>

        <div class="flex-1 px-4 py-4">
          <%= pathogen_supporting(variant: :muted) do %>
            Hover or focus each rail icon to read the section label. The main surface stays uncluttered while keyboard
            users still get an accessible name on focus.
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Breadcrumb trail" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Breadcrumb links can use <%= pathogen_code { "placement: :bottom" } %> so labels stay inside the page header.
    <% end %>

    <div
      class="
        rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] px-4
        py-3
      "
    >
      <nav class="flex flex-wrap items-center gap-2 text-sm">
        <%= render Pathogen::Link.new(href: "/", aria: { label: "Workspace home" }) do |link| %>
          <% link.with_tooltip(text: "Return to workspace home", placement: :bottom) %>
          <%= icon("house", class: "size-4 text-[var(--pvc-color-text-muted)]") %>
        <% end %>

        <span class="text-[var(--pvc-color-text-muted)]">/</span>

        <%= render Pathogen::Link.new(href: "/projects") do |link| %>
          <% link.with_tooltip(text: "View all projects", placement: :bottom) %> Projects
        <% end %>

        <span class="text-[var(--pvc-color-text-muted)]">/</span>

        <%= render Pathogen::Link.new(href: "/projects/wgs-bacterial") do |link| %>
          <% link.with_tooltip(text: "Open WGS bacterial project", placement: :bottom) %> WGS bacterial
        <% end %>

        <span class="text-[var(--pvc-color-text-muted)]">/</span>
        <span class="text-[var(--pvc-color-text-muted)]">RUN-2026-0142</span>
      </nav>
    </div>
  </section>
</div>
