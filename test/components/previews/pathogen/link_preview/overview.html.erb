<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Inline navigation" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "Pathogen::Link" } %> for underlined inline navigation inside body copy, help text, and
      table cells. Accent colour appears on hover through <%= pathogen_code { "--pvc-color-accent-strong" } %>.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_text do %>
        Specimen <strong>SPC-24018</strong> was submitted on 12 May 2026. Review the
        <%= pathogen_link(href: "#qc-summary") { "QC summary" } %> before approving the run, or open the
        <%= pathogen_link(href: "#run-history") { "run history" } %> for prior attempts.
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Detail panel links" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Group related links in compact stacks when they support the same record or task. Keep labels specific.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
      <div class="border-b border-[var(--pvc-color-border)] px-4 py-3">
        <%= pathogen_heading(level: 5, class: "font-semibold") { "Run INV-8821" } %>
        <%= pathogen_supporting(variant: :muted, class: "mt-1") { "Salmonella enterica · Whole genome assembly" } %>
      </div>

      <ul class="divide-y divide-[var(--pvc-color-border)] px-4 py-2 text-sm">
        <li class="py-2">
          <%= pathogen_link(href: "#protocol") { "View sequencing protocol" } %>
        </li>

        <li class="py-2">
          <%= pathogen_link(href: "#metadata") { "Edit specimen metadata" } %>
        </li>

        <li class="py-2">
          <%= pathogen_link(href: "#attachments") { "Download attachment bundle" } %>
        </li>
      </ul>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "External links" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      External hosts open in a new tab with <%= pathogen_code { "rel=\"noopener noreferrer\"" } %> and an accessible
      label when the link text alone is not enough context.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_text do %>
        Reference assembly
        <%= pathogen_link(href: "https://www.ncbi.nlm.nih.gov/") { "NCBI GenBank record GCA_000006945.2" } %> for
        lineage comparison.
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "With tooltip" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Add a tooltip when the label is short but the destination or side effect needs clarification. Tooltip content
      supplements the link; it does not replace the visible label.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_text do %>
        Export status is pending validation. See
        <%= pathogen_link(href: "#export-policy") do |component| %>
          <%= component.with_tooltip(text: "Exports are retained for 30 days in the project workspace.") %> export
          retention policy
        <% end %>
        for storage limits.
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Link vs button" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Links navigate or reveal related content. Buttons commit actions. In toolbars and form footers, prefer
      <%= pathogen_code { "Pathogen::Button" } %>. In prose and inline help, prefer
      <%= pathogen_code { "Pathogen::Link" } %>.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
        <%= pathogen_supporting(tag: :span, variant: :muted) { "Inline:" } %>
        <%= pathogen_link(href: "#sample") { "Open specimen SPC-24018" } %>

        <%= pathogen_supporting(tag: :span, variant: :muted, class: "ml-2") { "Action:" } %>
        <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, text: 'Approve run') %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Focus and keyboard" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Tab to a link and confirm the focus ring uses <%= pathogen_code { "--pvc-color-focus" } %> in light and dark mode.
      Hover thickens the underline without removing readable contrast.
    <% end %>

    <div
      class="
        rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface-muted)] p-4
      "
    >
      <%= pathogen_link(href: "#focus-example") { "Tab here to inspect focus ring" } %>
    </div>
  </section>
</div>
