<section class="space-y-4 p-4">
  <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">
    Toggle-style actions
  </h2>

  <%= render Pathogen::Toolbar.new(label: 'Display options') do %>
    <%= render Pathogen::Toolbar::Button.new(pressed: true) do %>
      Compact rows
    <% end %>

    <%= render Pathogen::Toolbar::Button.new(pressed: false) do %>
      Group by status
    <% end %>

    <%= render Pathogen::Toolbar::Button.new do %>
      Export
    <% end %>
  <% end %>

  <p class="text-sm text-neutral-600 dark:text-neutral-400">
    Pressed states are consumer-owned. The toolbar only reflects the current state through aria-pressed.
  </p>

  <p class="text-sm text-neutral-600 dark:text-neutral-400">
    This preview intentionally leaves pressed-state updates to consumer logic.
  </p>
</section>
