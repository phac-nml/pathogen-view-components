<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 2, class: "mb-2") { "Operator account settings" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Vertical tabs in a settings layout with URL sync so the active section stays bookmarkable.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= render(Pathogen::Tabs.new(
        id: 'operator-settings-tabs',
        label: 'Operator account settings',
        orientation: :vertical,
        sync_url: true
      )) do |tabs| %>
        <% tabs.with_tab(id: 'tab-profile', label: 'Profile', selected: true) %>
        <% tabs.with_tab(id: 'tab-access', label: 'Access') %>
        <% tabs.with_tab(id: 'tab-notifications', label: 'Notifications') %>

        <% tabs.with_panel(id: 'panel-profile', tab_id: 'tab-profile') do %>
          <dl class="space-y-3 text-[length:var(--type-control)]">
            <div>
              <dt class="font-semibold text-[var(--pvc-color-text)]">Display name</dt>
              <dd class="text-[var(--pvc-color-text-muted)]">lab-seq-review</dd>
            </div>
            <div>
              <dt class="font-semibold text-[var(--pvc-color-text)]">Organization</dt>
              <dd class="text-[var(--pvc-color-text-muted)]">Provincial public health lab</dd>
            </div>
            <div>
              <dt class="font-semibold text-[var(--pvc-color-text)]">Email</dt>
              <dd class="text-[var(--pvc-color-text-muted)]">seq.review@example.ca</dd>
            </div>
          </dl>
        <% end %>

        <% tabs.with_panel(id: 'panel-access', tab_id: 'tab-access') do %>
          <%= pathogen_list(variant: :muted) do |list| %>
            <% list.with_item { "Run review — granted" } %>
            <% list.with_item { "Protocol edit — granted" } %>
            <% list.with_item { "User administration — denied" } %>
          <% end %>
        <% end %>

        <% tabs.with_panel(id: 'panel-notifications', tab_id: 'tab-notifications') do %>
          <dl class="space-y-3 text-[length:var(--type-control)]">
            <div class="flex items-center justify-between gap-4 border-b border-[var(--pvc-color-border)] pb-2">
              <dt class="font-semibold text-[var(--pvc-color-text)]">QC failure alerts</dt>
              <dd class="text-[var(--pvc-color-text-muted)]">Email</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="font-semibold text-[var(--pvc-color-text)]">Run completion</dt>
              <dd class="text-[var(--pvc-color-text-muted)]">In-app only</dd>
            </div>
          </dl>
        <% end %>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 2, class: "mb-2") { "Form footer with tabs above" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Tabs organize read-only review sections; the primary action stays in the form footer below.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= render(Pathogen::Tabs.new(id: 'submission-review-tabs', label: 'Submission review')) do |tabs| %>
        <% tabs.with_tab(id: 'tab-checklist', label: 'Checklist', selected: true) %>
        <% tabs.with_tab(id: 'tab-attachments', label: 'Attachments') %>

        <% tabs.with_panel(id: 'panel-checklist', tab_id: 'tab-checklist') do %>
          <%= pathogen_list(variant: :muted) do |list| %>
            <% list.with_item { "Metadata complete" } %>
            <% list.with_item { "Consent on file" } %>
            <% list.with_item { "QC thresholds met" } %>
          <% end %>
        <% end %>

        <% tabs.with_panel(id: 'panel-attachments', tab_id: 'tab-attachments') do %>
          <%= pathogen_text(variant: :muted) { "chain_of_custody.pdf · lab_requisition.pdf" } %>
        <% end %>
      <% end %>

      <div class="mt-6 flex justify-end gap-2 border-t border-[var(--pvc-color-border)] pt-4">
        <%= render Pathogen::Button.new(tone: :neutral, emphasis: :outline, text: 'Return to queue') %>
        <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, text: 'Approve submission') %>
      </div>
    </div>
  </section>
</div>
