<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">Keyboard navigation</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      Tabs follow the W3C automatic activation pattern. Focus a tab, then use arrow keys to move and activate.
      <kbd class="rounded-sm border border-[var(--pvc-color-border-strong)] px-1.5 py-0.5 text-xs">Home</kbd> and
      <kbd class="rounded-sm border border-[var(--pvc-color-border-strong)] px-1.5 py-0.5 text-xs">End</kbd>
      jump to the first and last tab. Press
      <kbd class="rounded-sm border border-[var(--pvc-color-border-strong)] px-1.5 py-0.5 text-xs">Tab</kbd>
      to leave the tab list and enter the panel.
    </p>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= render(Pathogen::Tabs.new(id: 'keyboard-demo-tabs', label: 'Specimen review sections')) do |tabs| %>
        <% tabs.with_tab(id: 'kbd-tab-collection', label: 'Collection', selected: true) %>
        <% tabs.with_tab(id: 'kbd-tab-lab', label: 'Lab results') %>
        <% tabs.with_tab(id: 'kbd-tab-qc', label: 'QC flags') %>
        <% tabs.with_tab(id: 'kbd-tab-audit', label: 'Audit') %>

        <% tabs.with_panel(id: 'kbd-panel-collection', tab_id: 'kbd-tab-collection') do %>
          <dl class="grid gap-3 text-sm sm:grid-cols-2">
            <div>
              <dt class="font-semibold text-[var(--pvc-color-text)]">Specimen ID</dt>
              <dd class="font-mono text-[var(--pvc-color-text-muted)]">SPEC-2026-00891</dd>
            </div>
            <div>
              <dt class="font-semibold text-[var(--pvc-color-text)]">Collected</dt>
              <dd class="text-[var(--pvc-color-text-muted)]">2026-06-09</dd>
            </div>
          </dl>
        <% end %>

        <% tabs.with_panel(id: 'kbd-panel-lab', tab_id: 'kbd-tab-lab') do %>
          <p class="text-sm text-[var(--pvc-color-text-muted)]">
            Culture negative. WGS pending on paired isolate SPEC-2026-00891-A.
          </p>
        <% end %>

        <% tabs.with_panel(id: 'kbd-panel-qc', tab_id: 'kbd-tab-qc') do %>
          <p class="text-sm text-[var(--pvc-color-warning)]">Coverage below threshold on contig 3 — review required.</p>
        <% end %>

        <% tabs.with_panel(id: 'kbd-panel-audit', tab_id: 'kbd-tab-audit') do %>
          <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
            Last updated by lab-seq-review at 2026-06-10 14:32 UTC.
          </p>

          <%= render Pathogen::Button.new(tone: :primary, emphasis: :solid, text: 'Open audit log') %>
        <% end %>
      <% end %>
    </div>
  </section>

  <section>
    <h2 class="mb-2 text-base font-semibold text-[var(--pvc-color-text)]">ARIA wiring</h2>

    <p class="mb-4 text-sm text-[var(--pvc-color-text-muted)]">
      The component sets roles, labels, and roving tabindex so screen readers announce tab lists, selection, and panels
      consistently.
    </p>

    <div class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <h3 class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Tab list</h3>

        <dl class="space-y-2 text-sm">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">role</dt>
            <dd class="text-[var(--pvc-color-text-muted)]"><code>tablist</code> on <code>nav</code></dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">aria-label</dt>
            <dd class="text-[var(--pvc-color-text-muted)]">Names the tab group</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">aria-orientation</dt>
            <dd class="text-[var(--pvc-color-text-muted)]"><code>horizontal</code> or <code>vertical</code></dd>
          </div>
        </dl>
      </div>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
        <h3 class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Tab buttons</h3>

        <dl class="space-y-2 text-sm">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">role</dt>
            <dd class="text-[var(--pvc-color-text-muted)]"><code>tab</code> on native <code>button</code></dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">aria-selected</dt>
            <dd class="text-[var(--pvc-color-text-muted)]"><code>true</code> on the active tab only</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">tabindex</dt>
            <dd class="text-[var(--pvc-color-text-muted)]">Roving: <code>0</code> active, <code>-1</code> inactive</dd>
          </div>
        </dl>
      </div>

      <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4 lg:col-span-2">
        <h3 class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Panels</h3>

        <dl class="grid gap-2 text-sm sm:grid-cols-2">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">role</dt>
            <dd class="text-[var(--pvc-color-text-muted)]"><code>tabpanel</code></dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">aria-labelledby</dt>
            <dd class="text-[var(--pvc-color-text-muted)]">References the controlling tab id</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">hidden</dt>
            <dd class="text-[var(--pvc-color-text-muted)]">Native attribute toggled for inactive panels</dd>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-[var(--pvc-color-accent-strong)]">data-state</dt>
            <dd class="text-[var(--pvc-color-text-muted)]"><code>active</code> / <code>inactive</code> for styling hooks</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>
</div>
