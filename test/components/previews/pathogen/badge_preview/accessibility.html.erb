<div class="flex max-w-3xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 5, class: 'mb-2 text-[var(--pvc-color-text)]') { 'Text carries meaning' } %>

    <%= pathogen_supporting(variant: :muted, class: 'mb-4 text-[var(--pvc-color-text-muted)]') do %>
      Badges are plain spans by default — not live regions, not controls. Screen readers announce the visible label,
      and <code>aria-label</code> is rejected so the accessible name can never drift from it. Prefer host
      <code>role="status"</code> only when this badge node itself updates live.
    <% end %>

    <div
      class="
        flex flex-wrap items-center gap-2 rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)] p-4
      "
    >
      <%= pathogen_badge(text: 'Ready', tone: :success) %>
      <%= pathogen_badge(text: 'Failed', tone: :danger) %>
      <%= pathogen_badge(text: 'Ready', tone: :success, role: 'status', test_selector: 'live-opt-in') %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 5, class: 'mb-2 text-[var(--pvc-color-text)]') { 'Leading visual is decorative' } %>

    <%= pathogen_supporting(variant: :muted, class: 'mb-4 text-[var(--pvc-color-text-muted)]') do %>
      Optional leading visuals are <code>aria-hidden</code> and <code>inert</code>, so slotted content stays decorative
      and cannot take focus. Icon-only badges are rejected — hosts must always pass text.
    <% end %>

    <div
      class="
        flex flex-wrap items-center gap-2 rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)] p-4
      "
    >
      <%= pathogen_badge(text: 'Required', tone: :accent) do |badge| %>
        <% badge.with_leading_visual do %>
          <svg
            aria-hidden="true"
            viewBox="0 0 16 16"
            class="size-3"
            fill="currentColor"
          >
            <path
              d="
                M8 1.5a.75.75 0 0 1 .75.75v5h5a.75.75 0 0 1 0 1.5h-5v5a.75.75 0 0 1-1.5 0v-5h-5a.75.75 0 0 1
                0-1.5h5v-5A.75.75 0 0 1 8 1.5Z
              "
            />
          </svg>
        <% end %>
      <% end %>

      <%= pathogen_badge(text: 'Bot', tone: :neutral) do |badge| %>
        <% badge.with_leading_visual do %>
          <svg
            aria-hidden="true"
            viewBox="0 0 16 16"
            class="size-3"
            fill="currentColor"
          >
            <path
              d="
                M8 1a2.5 2.5 0 0 0-2.5 2.5V5H4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1.5V3.5A2.5
                2.5 0 0 0 8 1Zm0 1.5c.55 0 1 .45 1 1V5H7V3.5c0-.55.45-1 1-1ZM5.5 9a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm5 0a1
                1 0 1 1 0-2 1 1 0 0 1 0 2Z
              "
            />
          </svg>
        <% end %>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 5, class: 'mb-2 text-[var(--pvc-color-text)]') { 'Not for interaction' } %>

    <%= pathogen_supporting(variant: :muted, class: 'text-[var(--pvc-color-text-muted)]') do %>
      Do not use Badge for dismissible filters, selection chips, or notification counts. Those patterns need a dedicated
      interactive component so static labels never look like buttons.
    <% end %>
  </section>
</div>
