<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 5, class: 'mb-2 text-[var(--pvc-color-text)]') { 'Semantic tones' } %>

    <%= pathogen_supporting(variant: :muted, class: 'mb-4 text-[var(--pvc-color-text-muted)]') do %>
      Badges are static labels. Soft fill and a hairline border reinforce meaning that already lives in the text. Colour
      alone is never enough.
    <% end %>

    <div
      class="
        flex flex-wrap items-center gap-2 rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)] p-4
      "
    >
      <%= pathogen_badge(text: 'Queued', tone: :neutral) %>
      <%= pathogen_badge(text: 'Required', tone: :accent) %>
      <%= pathogen_badge(text: 'Ready', tone: :success) %>
      <%= pathogen_badge(text: 'Needs review', tone: :warning) %>
      <%= pathogen_badge(text: 'Failed', tone: :danger) %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 5, class: 'mb-2 text-[var(--pvc-color-text)]') { 'Workflow execution table' } %>

    <%= pathogen_supporting(variant: :muted, class: 'mb-4 text-[var(--pvc-color-text-muted)]') do %>
      Typical product usage: compact status and metadata in dense clinical grids.
    <% end %>

    <div
      class="
        overflow-hidden rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)]
      "
    >
      <table class="w-full text-left text-[length:var(--type-control)] text-[var(--pvc-color-text)]">
        <thead class="border-b border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)]">
          <tr>
            <th class="px-4 py-2 font-semibold" scope="col">Run</th>
            <th class="px-4 py-2 font-semibold" scope="col">Pipeline</th>
            <th class="px-4 py-2 font-semibold" scope="col">Status</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-[var(--pvc-color-border)]">
          <tr>
            <td class="px-4 py-2 font-mono text-[length:var(--type-meta)]">INEX_WORK_A1B2</td>

            <td class="px-4 py-2">
              <span class="inline-flex items-center gap-2">
                Genome assembly <%= pathogen_badge(text: 'v3.2.1', tone: :neutral) %>
              </span>
            </td>

            <td class="px-4 py-2"><%= pathogen_badge(text: 'Ready', tone: :success) %></td>
          </tr>

          <tr>
            <td class="px-4 py-2 font-mono text-[length:var(--type-meta)]">INEX_WORK_C3D4</td>

            <td class="px-4 py-2">
              <span class="inline-flex items-center gap-2">
                AMR detection <%= pathogen_badge(text: 'v1.0.0', tone: :neutral) %>
              </span>
            </td>

            <td class="px-4 py-2"><%= pathogen_badge(text: 'Running', tone: :accent) %></td>
          </tr>

          <tr>
            <td class="px-4 py-2 font-mono text-[length:var(--type-meta)]">INEX_WORK_E5F6</td>

            <td class="px-4 py-2">
              <span class="inline-flex items-center gap-2">
                Quality control <%= pathogen_badge(text: 'v2.4.0', tone: :neutral) %>
              </span>
            </td>

            <td class="px-4 py-2"><%= pathogen_badge(text: 'Failed', tone: :danger) %></td>
          </tr>

          <tr>
            <td class="px-4 py-2 font-mono text-[length:var(--type-meta)]">INEX_WORK_G7H8</td>

            <td class="px-4 py-2">
              <span class="inline-flex items-center gap-2">
                Metadata export <%= pathogen_badge(text: 'v0.9.1', tone: :neutral) %>
              </span>
            </td>

            <td class="px-4 py-2"><%= pathogen_badge(text: 'Needs review', tone: :warning) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 5, class: 'mb-2 text-[var(--pvc-color-text)]') { 'Form metadata' } %>

    <%= pathogen_supporting(variant: :muted, class: 'mb-4 text-[var(--pvc-color-text-muted)]') do %>
      Short markers next to field legends stay quiet and scannable.
    <% end %>

    <fieldset
      class="
        flex flex-col gap-2 rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)] p-4
      "
    >
      <legend class="inline-flex items-center gap-2 px-1 font-semibold text-[var(--pvc-color-text)]">
        Read length <%= pathogen_badge(text: 'Required', tone: :accent) %>
      </legend>

      <%= pathogen_supporting(variant: :muted, class: 'text-[var(--pvc-color-text-muted)]') do %>
        Minimum reads per sample for this protocol step.
      <% end %>
    </fieldset>
  </section>
</div>
