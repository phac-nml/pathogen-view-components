<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Sample processing queue" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Status toasts confirm background work when the UI already shows the result. Warnings and errors use notification
      dialogs (focus moves in). Pair overlays with durable UI — the toaster notification log keeps a reviewable history.
    <% end %>

    <div
      class="
        relative min-h-96 overflow-hidden rounded-(--pvc-radius-panel) border
        border-(--pvc-color-border) bg-(--pvc-color-surface) p-4
      "
    >
      <dl class="grid gap-3 text-sm sm:grid-cols-2">
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Queue" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "Ontario weekly export" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Samples" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "24 assigned · 1 skipped" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Run" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted, class: "font-mono") { "B-2026-06" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Sync" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "Metadata update in progress" } %>
        </div>
      </dl>

      <%= render Pathogen::Toaster.new(
        position: :top_center,
        strategy: :absolute,
        turbo_permanent: false,
        max_visible: 4,
        list_id: 'flashes-overview'
      ) do %>
        <%= render Pathogen::Toast.new(
          type: :success,
          message: 'Batch assignment completed.',
          description: '24 samples moved to run B-2026-06.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :info,
          message: 'Sync running in background.',
          description: 'You can keep working while metadata updates.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :warning,
          message: 'One sample skipped.',
          description: 'Coverage threshold was below 95%.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :error,
          message: 'Upload failed.',
          description: 'The attachment exceeds the configured file-size limit.'
        ) %>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "When to use which mode" } %>

    <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4">
      <dl class="space-y-3 text-sm">
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Status toast" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) do %>
            Redundant success/info only. Auto-dismisses. No controls. Announced politely. Keep the same fact in page UI
            or the notification log.
          <% end %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Notification dialog" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) do %>
            Warnings, errors, dismissible, or actionable notifications. Focus moves in; no live-region announce. Prefer
            an in-flow banner when the message belongs next to the task.
          <% end %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Undo" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) do %>
            Put Undo in the page next to the changed item. An optional status toast may confirm the action; do not make
            the toast the only Undo path.
          <% end %>
        </div>
      </dl>
    </div>
  </section>
</div>
