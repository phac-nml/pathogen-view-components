<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Sample processing queue" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Status toasts (success/info) can peek-stack. This frame mixes in warning and error dialogs, so the toaster
      stays <%= pathogen_code { "flat" } %> — same rule as production.
    <% end %>

    <div
      class="
        relative min-h-96 overflow-hidden rounded-(--pvc-radius-panel) border
        border-(--pvc-color-border) bg-(--pvc-color-surface) p-4
      "
    >
      <dl class="grid gap-3 text-sm sm:grid-cols-2">
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Queue" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "Ontario weekly export" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Samples" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "24 assigned · 1 skipped" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Run" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted, class: "font-mono") { "B-2026-06" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Sync" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "Metadata update complete" } %>
        </div>
      </dl>

      <%= render Pathogen::Toaster.new(
        position: :top_center,
        strategy: :absolute,
        turbo_permanent: false,
        max_visible: 4,
        list_id: 'flashes-overview'
      ) do %>
        <%= render Pathogen::Toast.new(
          type: :success,
          message: 'Batch assignment completed.',
          description: '24 samples moved to run B-2026-06.',
          timeout: 60_000
        ) %>

        <%= render Pathogen::Toast.new(
          type: :info,
          message: 'Sync finished in background.',
          description: 'You can keep working in this queue.',
          timeout: 60_000
        ) %>

        <%= render Pathogen::Toast.new(
          type: :warning,
          message: 'One sample skipped.',
          description: 'Coverage threshold was below 95%.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :error,
          message: 'Upload failed.',
          description: 'The attachment exceeds the configured file-size limit.'
        ) %>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Modes" } %>

    <div class="grid gap-4 lg:grid-cols-2">
      <div
        class="
          relative min-h-48 overflow-hidden rounded-(--pvc-radius-panel) border
          border-(--pvc-color-border) bg-(--pvc-color-surface) p-4
        "
      >
        <%= pathogen_heading(level: 4, class: "mb-1") { "Status toast" } %>
        <%= pathogen_supporting(variant: :muted, class: "mb-3") do %>
          <%= pathogen_code { "type: :success" } %> · no controls · auto-dismiss
        <% end %>

        <%= render Pathogen::Toaster.new(
          position: :top_center,
          strategy: :absolute,
          turbo_permanent: false,
          max_visible: 1,
          list_id: 'flashes-mode-status'
        ) do %>
          <%= render Pathogen::Toast.new(
            type: :success,
            message: 'Filter preset saved.',
            description: 'Preset "Ontario weekly" is available to your team.',
            timeout: 60_000
          ) %>
        <% end %>
      </div>

      <div
        class="
          relative min-h-48 overflow-hidden rounded-(--pvc-radius-panel) border
          border-(--pvc-color-border) bg-(--pvc-color-surface) p-4
        "
      >
        <%= pathogen_heading(level: 4, class: "mb-1") { "Notification dialog" } %>
        <%= pathogen_supporting(variant: :muted, class: "mb-3") do %>
          <%= pathogen_code { "type: :error" } %> · focus in · dismiss required
        <% end %>

        <%= render Pathogen::Toaster.new(
          position: :top_center,
          strategy: :absolute,
          turbo_permanent: false,
          max_visible: 1,
          list_id: 'flashes-mode-dialog'
        ) do %>
          <%= render Pathogen::Toast.new(
            type: :error,
            message: 'Reference data stale.',
            description: 'Re-index before finalizing this outbreak report.'
          ) %>
        <% end %>
      </div>
    </div>
  </section>
</div>
