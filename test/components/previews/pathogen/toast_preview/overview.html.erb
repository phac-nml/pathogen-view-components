<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Sample processing queue" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Toasts confirm background work without blocking the current task. Status is carried by the icon and message —
      not decorative colour blocks.
    <% end %>

    <div
      class="
        relative min-h-96 overflow-hidden rounded-(--pvc-radius-panel) border
        border-(--pvc-color-border) bg-(--pvc-color-surface) p-4
      "
    >
      <dl class="grid gap-3 text-sm sm:grid-cols-2">
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Queue" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "Ontario weekly export" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Samples" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "24 assigned · 1 skipped" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Run" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted, class: "font-mono") { "B-2026-06" } %>
        </div>
        <div>
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Sync" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted) { "Metadata update in progress" } %>
        </div>
      </dl>

      <%= render Pathogen::Toaster.new(
        position: :bottom_right,
        strategy: :absolute,
        turbo_permanent: false,
        max_visible: 4,
        list_id: 'flashes-overview'
      ) do %>
        <%= render Pathogen::Toast.new(
          type: :success,
          message: 'Batch assignment completed.',
          description: '24 samples moved to run B-2026-06.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :info,
          message: 'Sync running in background.',
          description: 'You can keep working while metadata updates.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :warning,
          message: 'One sample skipped.',
          description: 'Coverage threshold was below 95%.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :error,
          message: 'Upload failed.',
          description: 'The attachment exceeds the configured file-size limit.'
        ) %>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Status types" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Semantic roles for success, warning, and error. Info stays quiet with a muted icon; reserve accent for actions
      inside the toast.
    <% end %>

    <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4">
      <dl class="space-y-3 text-sm">
        <div class="flex items-baseline justify-between gap-4 border-b border-(--pvc-color-border) pb-2">
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Success" } %>
          <dd class="font-mono text-(--pvc-color-success)">--pvc-color-success</dd>
        </div>
        <div class="flex items-baseline justify-between gap-4 border-b border-(--pvc-color-border) pb-2">
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Warning" } %>
          <dd class="font-mono text-(--pvc-color-warning)">--pvc-color-warning</dd>
        </div>
        <div class="flex items-baseline justify-between gap-4 border-b border-(--pvc-color-border) pb-2">
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Error" } %>
          <dd class="font-mono text-(--pvc-color-danger)">--pvc-color-danger</dd>
        </div>
        <div class="flex items-baseline justify-between gap-4">
          <%= pathogen_supporting(tag: :dt, class: "font-semibold") { "Info" } %>
          <%= pathogen_supporting(tag: :dd, variant: :muted, class: "font-mono") { "--pvc-color-text-muted" } %>
        </div>
      </dl>
    </div>
  </section>

  <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4 text-sm text-(--pvc-color-text-muted)">
    <%= pathogen_supporting(class: "font-semibold") { "Usage" } %>
    <%= pathogen_supporting(variant: :muted, class: "mt-2") do %>
      Mount a persistent <%= pathogen_code { "Pathogen::Toaster" } %> in the host layout (for example
      <%= pathogen_code { "#flashes" } %>) and stream <%= pathogen_code { "Pathogen::Toast" } %> instances into
      it after Turbo responses. Errors and actionable toasts do not auto-dismiss.
    <% end %>
  </div>
</div>
