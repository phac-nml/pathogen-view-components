<%# herb:formatter ignore %>

<div id="pv-toast-stream-root" data-list-id="flashes-stream-sim" data-interval-ms="<%= interval_ms %>" class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Turbo stream simulation" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      This preview mocks server responses by generating a full <%= pathogen_code { "turbo-stream" } %> payload
      and passing it to <%= pathogen_code { "Turbo.renderStreamMessage" } %>. A random toast is appended every
      <%= pathogen_code { "#{interval_ms}ms" } %> while streaming is active.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <%= render Pathogen::Button.new(
          text: 'Push event now',
          tone: :primary,
          emphasis: :outline,
          size: :small,
          'data-pv-stream-push': true
        ) %>

        <%= render Pathogen::Button.new(
          text: 'Start auto stream',
          tone: :neutral,
          emphasis: :outline,
          size: :small,
          'data-pv-stream-start': true
        ) %>

        <%= render Pathogen::Button.new(
          text: 'Pause stream',
          tone: :neutral,
          emphasis: :outline,
          size: :small,
          'data-pv-stream-stop': true
        ) %>

        <%= render Pathogen::Button.new(
          text: 'Clear toasts',
          tone: :neutral,
          emphasis: :ghost,
          size: :small,
          'data-pv-stream-clear': true
        ) %>
      </div>

      <div class="mb-4 grid gap-3 text-sm sm:grid-cols-2">
        <div>
          <%= pathogen_supporting(class: "font-semibold") { "Status" } %>
          <%= pathogen_supporting(variant: :muted, data: { pv_stream_status: true }) { "Connecting..." } %>
        </div>

        <div>
          <%= pathogen_supporting(class: "font-semibold") { "Events emitted" } %>
          <%= pathogen_supporting(variant: :muted, class: "font-mono", data: { pv_stream_count: true }) { "0" } %>
        </div>
      </div>

      <div
        class="
          relative min-h-[24rem] overflow-hidden rounded-[var(--pvc-radius-panel)] border
          border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)] p-4
        "
      >
        <%= pathogen_supporting(variant: :muted) do %>
          Simulated outbreak event channel. Notifications arrive asynchronously while the workspace remains interactive.
        <% end %>

        <%= render Pathogen::Toaster.new(
          position: :bottom_right,
          strategy: :absolute,
          turbo_permanent: false,
          max_visible: 4,
          list_id: 'flashes-stream-sim'
        ) %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "What this proves" } %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= pathogen_list(variant: :muted) do |list| %>
        <% list.with_item do %>
          Incoming stream messages mount real <%= pathogen_code { "Pathogen::Toast" } %> instances.
        <% end %>
        <% list.with_item do %>
          Auto-dismiss, focus restore, stack collapse, and live-region routing work under repeated updates.
        <% end %>
        <% list.with_item do %>
          The target list can be cleared with an <%= pathogen_code { "update" } %> stream action.
        <% end %>
      <% end %>
    </div>
  </section>

  <div class="hidden" aria-hidden="true">
    <template data-pv-stream-toast-template>
      <%= render Pathogen::Toast.new(
        type: :success,
        message: 'Metadata sync complete.',
        description: '19 newly published records were indexed.'
      ) %>
    </template>

    <template data-pv-stream-toast-template>
      <%= render Pathogen::Toast.new(
        type: :info,
        message: 'Background reconciliation running.',
        description: 'Remote sequencing updates are processing in batches.'
      ) %>
    </template>

    <template data-pv-stream-toast-template>
      <%= render Pathogen::Toast.new(
        type: :warning,
        message: 'One lineage annotation needs review.',
        description: 'Coverage dropped below the release threshold for SPEC-2026-1142.'
      ) %>
    </template>

    <template data-pv-stream-toast-template>
      <%= render Pathogen::Toast.new(
        type: :error,
        message: 'Submission export failed.',
        description: 'Connection to the provincial endpoint timed out.'
      ) %>
    </template>

    <template data-pv-stream-toast-template>
      <%= render Pathogen::Toast.new(
        type: :info,
        message: 'Undo release?',
        description: 'This publication can be rolled back for 10 minutes.'
      ) do |toast| %>
        <% toast.with_action do %>
          <%= render Pathogen::Button.new(size: :small, tone: :neutral, emphasis: :outline, text: 'Undo') %>
        <% end %>
      <% end %>
    </template>
  </div>
</div>

<script nonce="<%= request.content_security_policy_nonce %>">
  (function () {
    const root = document.getElementById("pv-toast-stream-root");
    if (!root || root.dataset.initialized === "true") return;
    root.dataset.initialized = "true";

    const listId = root.dataset.listId;
    const intervalMs = Number(root.dataset.intervalMs || "10000");
    const statusEl = root.querySelector("[data-pv-stream-status]");
    const countEl = root.querySelector("[data-pv-stream-count]");
    const pushBtn = root.querySelector("[data-pv-stream-push]");
    const startBtn = root.querySelector("[data-pv-stream-start]");
    const stopBtn = root.querySelector("[data-pv-stream-stop]");
    const clearBtn = root.querySelector("[data-pv-stream-clear]");
    const templates = Array.from(root.querySelectorAll("template[data-pv-stream-toast-template]"));

    let timerId = null;
    let emittedCount = 0;

    const setStatus = (message) => {
      if (statusEl) statusEl.textContent = message;
    };

    const setCount = (count) => {
      if (countEl) countEl.textContent = String(count);
    };

    const renderStream = (action, html) => {
      if (!window.Turbo || typeof window.Turbo.renderStreamMessage !== "function") return false;

      const payload = `<turbo-stream action="${action}" target="${listId}"><template>${html}</template></turbo-stream>`;
      window.Turbo.renderStreamMessage(payload);
      return true;
    };

    const appendRandomToast = () => {
      if (templates.length === 0) return;

      const selectedTemplate = templates[Math.floor(Math.random() * templates.length)];
      const toastHtml = selectedTemplate.innerHTML.trim();
      if (!toastHtml) return;

      if (!renderStream("append", toastHtml)) {
        const fallbackList = document.getElementById(listId);
        fallbackList?.insertAdjacentHTML("beforeend", toastHtml);
      }

      emittedCount += 1;
      setCount(emittedCount);
      setStatus(`Last event: ${new Date().toLocaleTimeString()}`);
    };

    const clearToasts = () => {
      if (!renderStream("update", "")) {
        const fallbackList = document.getElementById(listId);
        if (fallbackList) fallbackList.innerHTML = "";
      }

      setStatus("Toast list cleared.");
    };

    const startStream = () => {
      if (timerId) return;

      timerId = window.setInterval(appendRandomToast, intervalMs);
      setStatus(`Streaming every ${intervalMs}ms.`);
    };

    const stopStream = () => {
      if (!timerId) return;

      clearInterval(timerId);
      timerId = null;
      setStatus("Streaming paused.");
    };

    pushBtn?.addEventListener("click", appendRandomToast);
    startBtn?.addEventListener("click", startStream);
    stopBtn?.addEventListener("click", stopStream);
    clearBtn?.addEventListener("click", clearToasts);

    window.setTimeout(appendRandomToast, 900);
    startStream();

    document.addEventListener(
      "turbo:before-cache",
      () => {
        stopStream();
        root.dataset.initialized = "false";
      },
      { once: true }
    );
  })();
</script>
