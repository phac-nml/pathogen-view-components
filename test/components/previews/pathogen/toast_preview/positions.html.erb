<div class="space-y-6 bg-[var(--pvc-color-surface-muted)] p-6">
  <h2 class="text-base font-semibold text-[var(--pvc-color-text)]">Position presets</h2>

  <div class="grid gap-4 lg:grid-cols-2">
    <% {
      top_right: 'Top right',
      top_center: 'Top center',
      bottom_right: 'Bottom right',
      bottom_center: 'Bottom center'
    }.each do |position, label| %>
      <div
        class="
          relative min-h-[16rem] overflow-hidden rounded-[var(--pvc-radius-panel)] border
          border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4
        "
      >
        <h3 class="text-sm font-semibold text-[var(--pvc-color-text)]"><%= label %></h3>

        <p class="mt-1 text-sm text-[var(--pvc-color-text-muted)]">
          Use when overlays must avoid critical layout regions.
        </p>

        <%= render Pathogen::Toaster.new(
          position:,
          strategy: :absolute,
          turbo_permanent: false,
          max_visible: 2,
          list_id: "flashes-#{position}"
        ) do %>
          <%= render Pathogen::Toast.new(
            type: :success,
            message: "Position: #{label}",
            description: 'Preferred for this preview panel.',
            timeout: 0
          ) %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
