<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Stack behaviour" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Status toasts collapse into a scaled card deck until hovered, focused, or expanded via “+N more”. Peek-behind
      cards are <%= pathogen_code { "inert" } %>. Warnings/errors are notification dialogs — flat stack, focus moves in,
      no live announce. The toaster shows current notifications only.
    <% end %>

    <div
      class="
        relative min-h-112 overflow-hidden rounded-(--pvc-radius-panel) border
        border-(--pvc-color-border) bg-(--pvc-color-surface) p-4
      "
    >
      <%= pathogen_supporting(variant: :muted) do %>
        Outbreak report workspace — reference data stays editable while notifications stack at the top center.
      <% end %>

      <div class="mt-4 flex items-center gap-2">
        <%= render Pathogen::Button.new(size: :small, tone: :neutral, emphasis: :outline, text: 'Undo publication') %>
        <%= pathogen_supporting(variant: :muted, class: "text-sm") do %>
          In-page Undo (preferred). Optional status toast may confirm without owning the action.
        <% end %>
      </div>

      <%= render Pathogen::Toaster.new(
        position: :top_center,
        strategy: :absolute,
        turbo_permanent: false,
        max_visible: 3,
        list_id: 'flashes-stacking'
      ) do %>
        <%= render Pathogen::Toast.new(
          type: :success,
          message: 'Annotation import complete.',
          description: '4,391 records were indexed.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :info,
          message: 'Filter preset saved.',
          description: 'Preset "Ontario weekly report" is available to your team.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :info,
          message: 'Publication rolled back.',
          description: 'Use Undo publication above if you need to reverse again.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :warning,
          message: 'Connection is unstable.',
          description: 'Retries are running every 10 seconds.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :error,
          message: 'Reference data stale.',
          description: 'Re-index before finalizing this outbreak report.'
        ) %>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Accessibility contract" } %>

    <div class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4">
        <%= pathogen_heading(level: 4, class: "mb-3") { "Status toast" } %>
        <dl class="space-y-2 text-sm">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">role</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { pathogen_code { "listitem" } } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">announce</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { "polite status region (interrupt: assertive)" } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">focus</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { "not in tab order" } %>
          </div>
        </dl>
      </div>

      <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4">
        <%= pathogen_heading(level: 4, class: "mb-3") { "Notification dialog" } %>
        <dl class="space-y-2 text-sm">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">role</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { pathogen_code { 'dialog aria-modal="false"' } } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">announce</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { "none — focus moves into the dialog" } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">dismiss</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) do %>
              <kbd class="rounded-sm border border-(--pvc-color-border-strong) px-1.5 py-0.5 text-xs">Escape</kbd>
              when focused
            <% end %>
          </div>
        </dl>
      </div>
    </div>
  </section>
</div>
