<%# herb:formatter ignore %>

<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Stack behaviour" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Overflow toasts collapse into a quiet peek deck until the stack is hovered or focused. Errors announce
      assertively and stay visible. Actionable toasts pause auto-dismiss until dismissed.
    <% end %>

    <div
      class="
        relative min-h-112 overflow-hidden rounded-(--pvc-radius-panel) border
        border-(--pvc-color-border) bg-(--pvc-color-surface) p-4
      "
    >
      <%= pathogen_supporting(variant: :muted) do %>
        Outbreak report workspace — reference data and publication controls stay editable while notifications stack at
        the top center.
      <% end %>

      <%= render Pathogen::Toaster.new(
        position: :top_center,
        strategy: :absolute,
        turbo_permanent: false,
        max_visible: 3,
        list_id: 'flashes-stacking'
      ) do %>
        <%= render Pathogen::Toast.new(
          type: :success,
          message: 'Annotation import complete.',
          description: '4,391 records were indexed.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :info,
          message: 'Filter preset saved.',
          description: 'Preset "Ontario weekly report" is available to your team.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :warning,
          message: 'Connection is unstable.',
          description: 'Retries are running every 10 seconds.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :error,
          message: 'Reference data stale.',
          description: 'Re-index before finalizing this outbreak report.'
        ) %>

        <%= render Pathogen::Toast.new(
          type: :info,
          message: 'Undo publication?',
          description: 'This release can be rolled back for 10 minutes.'
        ) do |toast| %>
          <% toast.with_action do %>
            <%= render Pathogen::Button.new(size: :small, tone: :neutral, emphasis: :outline, text: 'Undo') %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Live regions" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Visible toasts use <%= pathogen_code { 'aria-live="off"' } %>. Screen-reader announcements route through
      dedicated polite and assertive regions in the toaster host.
    <% end %>

    <div class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4">
        <%= pathogen_heading(level: 4, class: "mb-3") { "Polite channel" } %>

        <dl class="space-y-2 text-sm">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">role</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { pathogen_code { "status" } } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">aria-live</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { pathogen_code { "polite" } } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">used for</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { "Success, info, and warning toasts" } %>
          </div>
        </dl>
      </div>

      <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4">
        <%= pathogen_heading(level: 4, class: "mb-3") { "Assertive channel" } %>

        <dl class="space-y-2 text-sm">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">role</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { pathogen_code { "alert" } } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">aria-live</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { pathogen_code { "assertive" } } %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">used for</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) { "Error toasts that must interrupt" } %>
          </div>
        </dl>
      </div>

      <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4 lg:col-span-2">
        <%= pathogen_heading(level: 4, class: "mb-3") { "Toast list item" } %>

        <dl class="grid gap-2 text-sm sm:grid-cols-2">
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">role</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) do %><%= pathogen_code { "listitem" } %> inside labelled <%= pathogen_code { "ol" } %><% end %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">aria-live</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) do %><%= pathogen_code { "off" } %> on the visible toast<% end %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">dismiss</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) do %>
              <kbd class="rounded-sm border border-(--pvc-color-border-strong) px-1.5 py-0.5 text-xs">Escape</kbd>
              when focused
            <% end %>
          </div>
          <div class="flex gap-2">
            <dt class="shrink-0 font-mono text-(--pvc-color-accent-strong)">timeout</dt>
            <%= pathogen_supporting(tag: :dd, variant: :muted) do %>Paused on hover or focus; errors use <%= pathogen_code { "0" } %><% end %>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <div class="rounded-(--pvc-radius-panel) border border-(--pvc-color-border) bg-(--pvc-color-surface) p-4 text-sm text-(--pvc-color-text-muted)">
    <%= pathogen_supporting(class: "font-semibold") { "Usage" } %>
    <%= pathogen_supporting(variant: :muted, class: "mt-2") do %>
      Hover or focus the toast stack to expand the peek deck and reveal overflow items. Pair status icons with visible
      text — type labels are exposed to screen readers via <%= pathogen_code { "sr-only" } %> prefixes.
    <% end %>
  </div>
</div>
