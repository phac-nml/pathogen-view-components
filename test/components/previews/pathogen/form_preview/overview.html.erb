<div class="flex max-w-4xl flex-col gap-8 p-4">
  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Checkbox fieldset" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Prefer <%= pathogen_code { "PathogenFormBuilder" } %> for labelled checkboxes. Pair each control with a label and
      optional help text using semantic text roles.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
        <fieldset class="space-y-4">
          <legend class="mb-3 text-sm font-semibold text-[var(--pvc-color-text)]">Export options</legend>

          <div class="flex items-start gap-3">
            <%= f.check_box :include_metadata, { checked: true }, "1", "0" %>

            <div class="min-w-0">
              <%= f.label :include_metadata, "Include metadata", class: "mb-1" %>

              <%= pathogen_supporting(tag: :p, variant: :muted, class: "m-0") do %>
                Add sample, project, and collection fields to the export.
              <% end %>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <%= f.check_box :include_analysis, {}, "1", "0" %>
            <%= f.label :include_analysis, "Include analysis results", class: "mb-0" %>
          </div>
        </fieldset>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Control states" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Checkboxes and radios share the same semantic surface, border, accent, and
      <%= pathogen_code { "--pvc-color-focus" } %> ring. Disabled controls keep reduced opacity without
      <%= pathogen_code { "neutral-950" } %> backgrounds.
    <% end %>

    <div class="overflow-x-auto rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]">
      <table class="w-full min-w-[36rem] border-collapse text-sm">
        <thead>
          <tr class="border-b border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface-muted)]">
            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "State" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Checkbox" } %>
            </th>

            <th scope="col" class="px-4 py-2 text-left">
              <%= pathogen_supporting(tag: :span, class: "font-semibold") { "Radio" } %>
            </th>
          </tr>
        </thead>

        <tbody class="divide-y divide-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]">
          <tr>
            <td class="px-4 py-3 align-middle">
              <%= pathogen_supporting(tag: :span, variant: :muted) { "Default" } %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
                <div class="flex items-center gap-3">
                  <%= f.check_box :preview_default, {}, "1", "0" %>
                  <%= f.label :preview_default, "Archive run", class: "mb-0" %>
                </div>
              <% end %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= pathogen_radio_button(attribute: :preview_radio, value: "draft", label: "Draft") %>
            </td>
          </tr>

          <tr>
            <td class="px-4 py-3 align-middle">
              <%= pathogen_supporting(tag: :span, variant: :muted) { "Checked" } %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
                <div class="flex items-center gap-3">
                  <%= f.check_box :preview_checked, { checked: true }, "1", "0" %>
                  <%= f.label :preview_checked, "Archive run", class: "mb-0" %>
                </div>
              <% end %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= pathogen_radio_button(attribute: :preview_radio_checked, value: "submitted", label: "Submitted", checked: true) %>
            </td>
          </tr>

          <tr>
            <td class="px-4 py-3 align-middle">
              <%= pathogen_supporting(tag: :span, variant: :muted) { "Disabled" } %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
                <div class="flex items-center gap-3">
                  <%= f.check_box :preview_disabled, { disabled: true }, "1", "0" %>
                  <%= f.label :preview_disabled, "Archive run", class: "mb-0" %>
                </div>
              <% end %>
            </td>

            <td class="px-4 py-3 align-middle">
              <%= pathogen_radio_button(attribute: :preview_radio_disabled, value: "locked", label: "Locked", disabled: true) %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Table row selection" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Pass <%= pathogen_code { "data: { table: true }" } %> to compact checkbox styling in dense grids.
    <% end %>

    <div class="overflow-x-auto rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]">
      <table class="w-full min-w-[32rem] border-separate border-spacing-0 text-left text-sm text-[var(--pvc-color-text)]">
        <thead>
          <tr>
            <th class="border-b border-[var(--pvc-color-border)] px-3 py-2">
              <%= check_box_tag "select_all", "1", false, id: "form_preview_select_all", data: { table: true } %>
            </th>

            <th class="border-b border-[var(--pvc-color-border)] px-3 py-2 font-semibold">Sample</th>
            <th class="border-b border-[var(--pvc-color-border)] px-3 py-2 font-semibold">Status</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td class="border-b border-[var(--pvc-color-border)] px-3 py-2">
              <%= check_box_tag "sample_ids[]", "spc-24018", true, id: "form_preview_sample_a", data: { table: true } %>
            </td>

            <td class="border-b border-[var(--pvc-color-border)] px-3 py-2">SPC-24018</td>

            <td class="border-b border-[var(--pvc-color-border)] px-3 py-2 text-[var(--pvc-color-text-muted)]">
              Ready
            </td>
          </tr>

          <tr>
            <td class="px-3 py-2">
              <%= check_box_tag "sample_ids[]", "spc-24019", false, id: "form_preview_sample_b", data: { table: true } %>
            </td>

            <td class="px-3 py-2">SPC-24019</td>
            <td class="px-3 py-2 text-[var(--pvc-color-text-muted)]">Pending QC</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Radio group" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Use <%= pathogen_code { "Pathogen::Form::RadioButton" } %> for mutually exclusive choices. Help text stays muted
      and associated through the component label stack.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <div class="space-y-4">
        <%= pathogen_radio_button(
              attribute: :analysis_type,
              value: "assembly",
              label: "De novo assembly",
              checked: true,
              help_text: "Recommended for unmatched isolates."
            ) %>

        <%= pathogen_radio_button(
              attribute: :analysis_type,
              value: "mapping",
              label: "Reference mapping",
              help_text: "Map reads against a known reference genome."
            ) %>

        <%= pathogen_radio_button(
              attribute: :analysis_type,
              value: "typing",
              label: "Molecular typing only"
            ) %>
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Switches" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Switches use <%= pathogen_code { "role=\"switch\"" } %> with visible On/Off state text. Checked tracks use
      <%= pathogen_code { "--pvc-color-accent-solid" } %>.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
        <div class="space-y-4">
          <%= f.switch :email_notifications, label: "Email notifications", checked: true %>
          <%= f.switch :qc_alerts, label: "QC alert digests" %>
        </div>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "External label pattern" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      When the label and description sit outside the switch control, wire <%= pathogen_code { "aria-labelledby" } %>
      and <%= pathogen_code { "aria-describedby" } %> explicitly.
    <% end %>

    <div class="rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)] p-4">
      <% switch_id = "form-preview-v2-samplesheet" %>
      <% label_id = "form-preview-v2-samplesheet-label" %>
      <% description_id = "form-preview-v2-samplesheet-description" %>

      <%= form_with url: "#", builder: Pathogen::FormBuilders::PathogenFormBuilder do |f| %>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
          <div class="min-w-0 flex-1">
            <%= label_tag switch_id, "V2 samplesheet", id: label_id,
                  class: "cursor-pointer text-sm font-semibold text-[var(--pvc-color-text)]" %>

            <%= pathogen_supporting(tag: :p, id: description_id, variant: :muted, class: "mt-1") do %>
              Try the redesigned samplesheet layout for dense review work.
            <% end %>
          </div>

          <%= render Pathogen::Form::Switch.new(
                form: f,
                attribute: :v2_samplesheet,
                id: switch_id,
                checked: true,
                aria: { labelledby: label_id, describedby: description_id }
              ) %>
        </div>
      <% end %>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Required fields" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Mark required inputs with an <%= pathogen_code { "<abbr class=\"req\">" } %> asterisk beside the label. Keep the
      marker in the tab order only when needed for comprehension.
    <% end %>

    <div
      class="
        max-w-sm rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface)] p-4
      "
    >
      <div class="flex flex-col gap-1.5">
        <label
          for="form-preview-contact-email"
          class="flex items-center gap-1 text-sm font-semibold text-[var(--pvc-color-text)]"
        >
          Contact email
          <abbr class="req text-[var(--pvc-color-danger-strong)] no-underline" title="required" aria-hidden="true">*</abbr>
        </label>

        <input
          id="form-preview-contact-email"
          type="email"
          autocomplete="email"
          placeholder="analyst@agency.ca"
          class="
            w-full rounded-[var(--pvc-radius-action)] border border-[var(--pvc-color-border-strong)]
            bg-[var(--pvc-color-surface)] px-3 py-2 text-sm text-[var(--pvc-color-text)] focus-visible:outline
            focus-visible:outline-2 focus-visible:outline-[var(--pvc-color-focus)] focus-visible:outline-offset-2
          "
        >
      </div>
    </div>
  </section>

  <section>
    <%= pathogen_heading(level: 3, class: "mb-2") { "Focus and keyboard" } %>

    <%= pathogen_supporting(variant: :muted, class: "mb-4") do %>
      Tab through each control and confirm the shared focus ring remains visible in light and dark mode. Checkbox,
      radio, switch, and text inputs should all resolve to <%= pathogen_code { "--pvc-color-focus" } %>.
    <% end %>

    <div
      class="
        rounded-[var(--pvc-radius-panel)] border border-[var(--pvc-color-border)]
        bg-[var(--pvc-color-surface-muted)] p-4
      "
    >
      <%= pathogen_switch(attribute: :focus_demo, id: "form-preview-focus-switch", label: "Tab here to inspect focus") %>
    </div>
  </section>
</div>
