<div class="pathogen-data-grid-preview-parity" style="display: grid; gap: 1rem;">
  <section class="pathogen-data-grid-preview-parity__variant">
    <h3 class="pathogen-data-grid-preview-parity__title">Fallback table path</h3>
    <%= render(Pathogen::DataGridComponent.new(
      caption: "Fallback table path comparison",
      sticky_columns: 1,
      virtual: false,
      rows: Pathogen::DataGridPreview::NAVIGATION_ROWS.first(6)
    )) do |grid|
      grid.with_column('Sample ID', key: :sample_id, width: 170)
      grid.with_column('Name', key: :name, width: 260)
      grid.with_column('Organism', key: :organism, width: 240)
      grid.with_column('Collected', key: :collected_at, width: 170)
      grid.with_column('Status', key: :status, width: 160)
    end %>
  </section>
  <section class="pathogen-data-grid-preview-parity__variant">
    <h3 class="pathogen-data-grid-preview-parity__title">Virtual lane path</h3>
    <%= render(Pathogen::DataGridComponent.new(
      caption: "Virtual lane path comparison",
      sticky_columns: 1,
      virtual: true,
      rows: Pathogen::DataGridPreview::NAVIGATION_ROWS.first(6)
    )) do |grid|
      grid.with_column('Sample ID', key: :sample_id, width: 170)
      grid.with_column('Name', key: :name, width: 260)
      grid.with_column('Organism', key: :organism, width: 240)
      grid.with_column('Collected', key: :collected_at, width: 170)
      grid.with_column('Status', key: :status, width: 160)
    end %>
  </section>
</div>
