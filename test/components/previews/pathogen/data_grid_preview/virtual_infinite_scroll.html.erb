<%# Rows endpoint is provided by the demo app at /demo/samples/rows.json. %>
<div class="flex min-h-0 w-full flex-col" style="height: min(56vh, 28rem);">
  <% if component %>
    <%= render component %>
  <% else %>
    <p class="text-sm text-[var(--pvc-color-text-muted)]">
      This preview requires the demo app. Run <code class="font-mono">bin/dev</code> from the
      <code class="font-mono">demo/</code> directory.
    </p>
  <% end %>
</div>
