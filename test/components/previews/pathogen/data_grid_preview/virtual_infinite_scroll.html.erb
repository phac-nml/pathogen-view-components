<%# Rows endpoint is provided by the demo app at /demo/samples/rows.json. %>
<div style="display: flex; flex-direction: column; width: 100%; height: min(56vh, 28rem); min-height: 0;">
  <% if component %>
    <%= render component %>
  <% else %>
    <p class="text-sm text-neutral-600">
      This preview requires the demo app. Run <code>bin/dev</code> from the <code>demo/</code> directory.
    </p>
  <% end %>
</div>
