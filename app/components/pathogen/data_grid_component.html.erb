<%= tag.div(**@system_arguments) do %>
  <% if caption? %>
    <%= tag.div(@caption, id: @caption_id, class: "pathogen-data-grid__caption") %>
  <% end %>

  <%= live_region if live_region? %>
  <%= metadata_warning if metadata_warning? %>

  <%= tag.div(class: 'pathogen-data-grid__scroll', data: { 'pathogen--data-grid-target': 'scrollContainer' }) do %>
    <% if @rows.blank? %>
      <%= empty_state? ? empty_state : default_empty_state %>
    <% else %>
      <%= tag.div(
        class: 'pathogen-data-grid__error-state',
        data: {
          'pathogen--data-grid-target': 'errorState',
          default_message: default_error_state_message
        },
        role: 'alert',
        aria: { live: 'assertive' },
        hidden: true
      ) do %>
        <%= error_state? ? error_state : default_error_state %>
      <% end %>

      <%= tag.div(class: 'pathogen-data-grid__state') do %>
        <% if virtual? %>
          <%= render Pathogen::DataGrid::VirtualStateComponent.new(grid: self) %>
        <% else %>
          <%= render Pathogen::DataGrid::RegularStateComponent.new(grid: self) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
  <% if @rows.present? %>
    <%= tag.p(
      scroll_hint_message,
      class: 'pathogen-data-grid__scroll-hint',
      data: { 'pathogen--data-grid-target': 'scrollHint' },
      hidden: true
    ) %>
    <%= tag.p(
      keyboard_help_text,
      id: keyboard_help_id,
      class: 'pathogen-data-grid__keyboard-help'
    ) %>
  <% end %>

  <%= footer if footer? %>
<% end %>
