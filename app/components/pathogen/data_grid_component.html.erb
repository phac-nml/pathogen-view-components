<%= tag.div(**@system_arguments) do %>
  <% if caption? %>
    <%= tag.div(@caption, id: @caption_id, class: "px-4 pt-4 text-left font-semibold text-[var(--pvc-data-grid-text-color)]", data: { pathogen_grid_caption: true }) %>
  <% end %>

  <%= live_region if live_region? %>
  <%= metadata_warning if metadata_warning? %>

  <%= tag.div(class: "max-w-full overflow-auto rounded-[inherit]", data: { 'pathogen--data-grid-target': 'scrollContainer' }) do %>
    <% if @rows.blank? && empty_state? %>
      <%= empty_state %>
    <% else %>
      <%= tag.table(**table_attributes) do %>
        <%= tag.thead do %>
          <%= tag.tr(class: "bg-[var(--pvc-data-grid-header-bg)] transition-colors", role: "row") do %>
            <% columns.each_with_index do |column, index| %>
              <%= tag.th(scope: "col", **column.header_cell_attributes(column_index: index)) do %>
                <% if column.default_header_label? %>
                  <%= tag.span(column.render_header, class: "inline-block font-semibold uppercase tracking-wider text-[var(--pvc-data-grid-text-muted-color)] whitespace-nowrap") %>
                <% else %>
                  <%= column.render_header %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <%= tag.tbody do %>
          <% @rows.each_with_index do |row, row_index| %>
            <%= tag.tr(class: "bg-[var(--pvc-data-grid-body-bg)] transition-colors", role: "row") do %>
              <% columns.each_with_index do |column, index| %>
                <% cell_payload = body_cell_payload(
                  column: column,
                  row: row,
                  column_index: index,
                  active: (default_active_row_index == row_index + 1 && index.zero?)
                ) %>

                <%= tag.td(
                  cell_payload[:content],
                  **column.body_cell_attributes(
                    row_index: row_index + 1,
                    column_index: index,
                    active: cell_payload[:focus_on_cell],
                    interactive: cell_payload[:interactive]
                  )
                ) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= footer if footer? %>
<% end %>
