<%= tag.div(**@system_arguments) do %>
  <% if caption? %>
    <%= tag.div(@caption, id: @caption_id, class: "pathogen-data-grid__caption") %>
  <% end %>

  <%= live_region if live_region? %>
  <%= metadata_warning if metadata_warning? %>

  <%= tag.div(class: 'pathogen-data-grid__scroll', data: { 'pathogen--data-grid-target': 'scrollContainer' }) do %>
    <% if !virtual? && @rows.blank? && empty_state? %>
      <%= empty_state %>
    <% else %>
      <%= tag.table(**table_attributes) do %>
        <%= tag.thead(class: 'pathogen-data-grid__header') do %>
          <% if virtual? %>
            <%= tag.tr(
              class: 'pathogen-data-grid__row pathogen-data-grid__row--header',
              role: 'row',
              data: { 'pathogen--data-grid-target': 'headerRow' }
            ) %>
          <% else %>
            <%= tag.tr(class: 'pathogen-data-grid__row pathogen-data-grid__row--header', role: 'row') do %>
              <% columns.each_with_index do |column, index| %>
                <%= tag.th(scope: "col", **column.header_cell_attributes(column_index: index)) do %>
                  <% if column.default_header_label? %>
                    <%= tag.span(column.render_header, class: 'pathogen-data-grid__header-label') %>
                  <% else %>
                    <%= column.render_header %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <%= tag.tbody(class: 'pathogen-data-grid__body', data: { 'pathogen--data-grid-target': 'body' }) do %>
          <% if virtual? %>
            <%= tag.tr(class: 'pathogen-data-grid__row pathogen-data-grid__row--placeholder', role: 'row') do %>
              <%= tag.td(
                'Loading virtual data grid…',
                class: 'pathogen-data-grid__cell pathogen-data-grid__cell--body pathogen-data-grid__cell--virtual-placeholder',
                role: 'gridcell',
                colspan: [column_count, 1].max,
                tabindex: -1
              ) %>
            <% end %>
          <% else %>
            <% @rows.each_with_index do |row, row_index| %>
              <%= tag.tr(class: 'pathogen-data-grid__row', role: 'row') do %>
                <% columns.each_with_index do |column, index| %>
                  <% cell_payload = body_cell_payload(
                    column: column,
                    row: row,
                    column_index: index,
                    active: (default_active_row_index == row_index + 1 && index.zero?)
                  ) %>
                  <%= tag.td(
                    cell_payload[:content],
                    **column.body_cell_attributes(
                      row_index: row_index + 1,
                      column_index: index,
                      active: cell_payload[:focus_on_cell],
                      interactive: cell_payload[:interactive]
                    )
                  ) %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= footer if footer? %>
<% end %>
