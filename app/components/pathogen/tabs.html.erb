<%= tag.div(
  id: "#{@id}-container",
  data: {
    controller: @system_arguments[:data][:controller],
    "pathogen--tabs-default-index-value" =>
      @system_arguments[:data]["pathogen--tabs-default-index-value"],
    "pathogen--tabs-sync-url-value" => @system_arguments[:data]["pathogen--tabs-sync-url-value"],
  },
  class: class_names(
    "font-sans text-[var(--pathogen-color-text-default)]",
    @orientation == :vertical ? "flex items-start gap-6" : "block",
  ),
) do %>
  <%= tag.nav(
    id: @id,
    role: "tablist",
    aria: {
      label: @label,
      orientation: @orientation,
    },
    class: class_names(
      "flex flex-wrap items-end gap-1 border-[var(--pathogen-color-border-default)]",
      @orientation == :vertical ? "min-w-[12.5rem] flex-col items-stretch border-r border-b-0 pr-3" : "border-b",
      @system_arguments[:class],
    ),
    **@system_arguments.except(:id, :data, :class),
  ) do %>
    <% tabs.each do |tab| %>
      <%= tab %>
    <% end %>
  <% end %>

  <%= tag.div(class: @orientation == :vertical ? "min-w-0 flex-1" : "mt-4") do %>
    <% panels.each do |panel| %>
      <%= panel %>
    <% end %>

    <% lazy_panels.each do |panel| %>
      <%= panel %>
    <% end %>
  <% end %>
<% end %>
