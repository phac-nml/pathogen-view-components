<%= tag.div(
  id: "#{@id}-container",
  data: {
    controller: @system_arguments[:data][:controller],
    "pathogen--tabs-default-index-value" =>
      @system_arguments[:data]["pathogen--tabs-default-index-value"],
    "pathogen--tabs-sync-url-value" => @system_arguments[:data]["pathogen--tabs-sync-url-value"],
  },
  class: class_names(
    "pathogen-tabs",
    "pathogen-tabs--vertical" => @orientation == :vertical,
    "pathogen-tabs--horizontal" => @orientation != :vertical,
  ),
) do %>
  <%= tag.nav(
    id: @id,
    role: "tablist",
    aria: {
      label: @label,
      orientation: @orientation,
    },
    class: class_names("pathogen-tabs__list", @system_arguments[:class]),
    **@system_arguments.except(:id, :data, :class),
  ) do %>
    <% tabs.each do |tab| %>
      <%= tab %>
    <% end %>
  <% end %>

  <%= tag.div(class: "pathogen-tabs__panels") do %>
    <% panels.each do |panel| %>
      <%= panel %>
    <% end %>

    <% lazy_panels.each do |panel| %>
      <%= panel %>
    <% end %>
  <% end %>
<% end %>
