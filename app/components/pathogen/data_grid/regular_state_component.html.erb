<%= tag.table(**@grid.table_attributes) do %>
  <%= tag.thead(class: 'pvc-data-grid__header') do %>
    <%= tag.tr(class: 'pvc-data-grid__row pvc-data-grid__row--header', role: 'row') do %>
      <% @grid.columns.each_with_index do |column, index| %>
        <%= header_cell_tag(tag_name: :th, column: column, column_index: index, aria_column_index: nil, scope: 'col') %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.tbody(class: 'pvc-data-grid__body') do %>
    <% @grid.rows.each_with_index do |row, row_index| %>
      <%= tag.tr(class: row_classes, role: 'row') do %>
        <% @grid.columns.each_with_index do |column, index| %>
          <%= body_cell_tag(
            tag_name: :td,
            column: column,
            row: row,
            row_index: row_index,
            column_index: index,
            aria_column_index: nil
          ) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
