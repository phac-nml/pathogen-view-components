<% pinned_columns = @grid.virtual_pinned_column_entries %>
<% center_columns = @grid.virtual_center_column_entries %>

<%= tag.div(
  class: body_row_classes,
  role: 'row',
  aria: { rowindex: aria_row_index(local_row_index) },
  'data-pvc-data-grid-global-row-index': global_row_index
) do %>
  <%= tag.div(
    class: body_pinned_lane_classes,
    'data-pvc-data-grid-lane': 'pinned',
    role: 'presentation',
    style: @grid.virtual_lane_row_style(pinned_columns)
  ) do %>
    <% pinned_columns.each do |column, index| %>
      <%= body_cell_tag(
        tag_name: :div,
        column: column,
        row: @row,
        row_index: local_row_index,
        column_index: index,
        aria_column_index: index + 1
      ) %>
    <% end %>
  <% end %>

  <%= tag.div(
    class: body_center_lane_classes,
    'data-pvc-data-grid-lane': 'center',
    role: 'presentation',
    style: @grid.virtual_lane_row_style(center_columns)
  ) do %>
    <% center_columns.each do |column, index| %>
      <%= body_cell_tag(
        tag_name: :div,
        column: column,
        row: @row,
        row_index: local_row_index,
        column_index: index,
        aria_column_index: index + 1,
        virtual_column_index: index
      ) %>
    <% end %>
  <% end %>
<% end %>
