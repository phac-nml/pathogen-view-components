<%= tag.div(**@grid.table_attributes) do %>
  <% pinned_columns = @grid.virtual_pinned_column_entries %>
  <% center_columns = @grid.virtual_center_column_entries %>

  <%= tag.div(
    @grid.virtual_loading_text,
    class: virtual_status_classes,
    data: {
      'pathogen--data-grid-target': 'virtualStatus',
      loading_text: @grid.virtual_loading_text,
      loaded_text: @grid.virtual_loaded_text
    },
    role: 'status',
    aria: { live: 'polite' }
  ) %>

  <%= tag.div(
    class: header_row_classes,
    role: 'row',
    aria: { rowindex: 1 },
    style: @grid.row_style
  ) do %>
    <%= tag.div(
      class: header_pinned_lane_classes,
      'data-pathogen-data-grid-lane': 'pinned',
      role: 'presentation',
      style: @grid.virtual_lane_row_style(pinned_columns)
    ) do %>
      <% pinned_columns.each do |column, index| %>
        <%= header_cell_tag(tag_name: :div, column: column, column_index: index, aria_column_index: index + 1) %>
      <% end %>
    <% end %>

    <%= tag.div(
      class: header_center_lane_classes,
      'data-pathogen-data-grid-lane': 'center',
      role: 'presentation',
      style: @grid.virtual_lane_row_style(center_columns)
    ) do %>
      <% center_columns.each do |column, index| %>
        <%= header_cell_tag(
          tag_name: :div,
          column: column,
          column_index: index,
          aria_column_index: index + 1,
          virtual_column_index: index
        ) %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.div(class: viewport_classes, data: { 'pathogen--data-grid-target': 'viewport' }) do %>
    <%= tag.div(class: spacer_classes) %>

    <% @grid.rows.each_with_index do |row, row_index| %>
      <%= tag.div(
        class: body_row_classes,
        role: 'row',
        aria: { rowindex: aria_row_index(row_index) },
        style: @grid.row_style
      ) do %>
        <%= tag.div(
          class: body_pinned_lane_classes,
          'data-pathogen-data-grid-lane': 'pinned',
          role: 'presentation',
          style: @grid.virtual_lane_row_style(pinned_columns)
        ) do %>
          <% pinned_columns.each do |column, index| %>
            <%= body_cell_tag(
              tag_name: :div,
              column: column,
              row: row,
              row_index: row_index,
              column_index: index,
              aria_column_index: index + 1
            ) %>
          <% end %>
        <% end %>

        <%= tag.div(
          class: body_center_lane_classes,
          'data-pathogen-data-grid-lane': 'center',
          role: 'presentation',
          style: @grid.virtual_lane_row_style(center_columns)
        ) do %>
          <% center_columns.each do |column, index| %>
            <%= body_cell_tag(
              tag_name: :div,
              column: column,
              row: row,
              row_index: row_index,
              column_index: index,
              aria_column_index: index + 1,
              virtual_column_index: index
            ) %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
