<%= tag.div(**@grid.table_attributes) do %>
  <% pinned_columns = @grid.virtual_pinned_column_entries %>
  <% center_columns = @grid.virtual_center_column_entries %>

  <%= tag.div(
    @grid.virtual_loading_text,
    class: 'pathogen-data-grid__virtual-status',
    data: {
      'pathogen--data-grid-target': 'virtualStatus',
      loading_text: @grid.virtual_loading_text,
      loaded_text: @grid.virtual_loaded_text
    },
    role: 'status',
    aria: { live: 'polite' }
  ) %>

  <%= tag.div(
    class: 'pathogen-data-grid__row pathogen-data-grid__row--header',
    role: 'row',
    aria: { rowindex: 1 },
    style: @grid.row_style
  ) do %>
    <%= tag.div(
      class: 'pathogen-data-grid__lane pathogen-data-grid__lane--pinned',
      'data-pathogen-data-grid-lane': 'pinned',
      role: 'presentation',
      style: @grid.virtual_lane_row_style(pinned_columns)
    ) do %>
      <% pinned_columns.each do |column, index| %>
        <%= header_cell_tag(tag_name: :div, column: column, column_index: index, aria_column_index: index + 1) %>
      <% end %>
    <% end %>

    <%= tag.div(
      class: 'pathogen-data-grid__lane pathogen-data-grid__lane--center',
      'data-pathogen-data-grid-lane': 'center',
      role: 'presentation',
      style: @grid.virtual_lane_row_style(center_columns)
    ) do %>
      <% center_columns.each do |column, index| %>
        <%= header_cell_tag(
          tag_name: :div,
          column: column,
          column_index: index,
          aria_column_index: index + 1,
          virtual_column_index: index
        ) %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.div(class: 'pathogen-data-grid__viewport', data: { 'pathogen--data-grid-target': 'viewport' }) do %>
    <%= tag.div(class: 'pathogen-data-grid__spacer') %>
    <% @grid.rows.each_with_index do |row, row_index| %>
      <%= tag.div(
        class: 'pathogen-data-grid__row',
        role: 'row',
        aria: { rowindex: aria_row_index(row_index) },
        style: @grid.row_style
      ) do %>
        <%= tag.div(
          class: 'pathogen-data-grid__lane pathogen-data-grid__lane--pinned',
          'data-pathogen-data-grid-lane': 'pinned',
          role: 'presentation',
          style: @grid.virtual_lane_row_style(pinned_columns)
        ) do %>
          <% pinned_columns.each do |column, index| %>
            <%= body_cell_tag(
              tag_name: :div,
              column: column,
              row: row,
              row_index: row_index,
              column_index: index,
              aria_column_index: index + 1
            ) %>
          <% end %>
        <% end %>

        <%= tag.div(
          class: 'pathogen-data-grid__lane pathogen-data-grid__lane--center',
          'data-pathogen-data-grid-lane': 'center',
          role: 'presentation',
          style: @grid.virtual_lane_row_style(center_columns)
        ) do %>
          <% center_columns.each do |column, index| %>
            <%= body_cell_tag(
              tag_name: :div,
              column: column,
              row: row,
              row_index: row_index,
              column_index: index,
              aria_column_index: index + 1,
              virtual_column_index: index
            ) %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
