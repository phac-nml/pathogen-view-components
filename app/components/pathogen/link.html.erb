<%= render Pathogen::ConditionalWrapper.new(
  condition: tooltip?,
  tag: :div,
  class: "inline-block",
  'data-controller': 'pathogen--tooltip',
  'data-pathogen--tooltip-portal-aria-label-value': Pathogen::Tooltip.portal_aria_label
) do %>
  <%= render(Pathogen::BaseComponent.new(**@link_system_arguments)) do %>
    <%= content %>

    <% if @external_link %>
      <span class="sr-only"><%= t('.new_window_label') %></span>
    <% end %>
  <% end %>

  <%= tooltip if tooltip? %>
<% end %>
