<% if render_eager? %>
  <%= helpers.turbo_frame_tag(@frame_id) { content } %>
<% else %>
  <%= helpers.turbo_frame_tag(
    @frame_id,
    src: @src_path,
    loading: :lazy,
    refresh: @refresh,
  ) {
    tag.div(class: "pathogen-tabs__skeleton", aria: { hidden: true }) {
      tag.div(class: "pathogen-tabs__skeleton-lines") {
        safe_join([
          tag.div(class: "pathogen-tabs__skeleton-line pathogen-tabs__skeleton-line--title"),
          tag.div(class: "pathogen-tabs__skeleton-paragraph") {
            safe_join([
              tag.div(class: "pathogen-tabs__skeleton-line pathogen-tabs__skeleton-line--full"),
              tag.div(class: "pathogen-tabs__skeleton-line pathogen-tabs__skeleton-line--long"),
              tag.div(class: "pathogen-tabs__skeleton-line pathogen-tabs__skeleton-line--medium"),
              tag.div(class: "pathogen-tabs__skeleton-line pathogen-tabs__skeleton-line--medium"),
              tag.div(class: "pathogen-tabs__skeleton-line pathogen-tabs__skeleton-line--medium"),
              tag.div(class: "pathogen-tabs__skeleton-line pathogen-tabs__skeleton-line--medium")
            ])
          }
        ])
      }
    }
  } %>
<% end %>
