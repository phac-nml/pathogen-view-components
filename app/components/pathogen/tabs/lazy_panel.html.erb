<% if render_eager? %>
  <%= helpers.turbo_frame_tag(@frame_id) { content } %>
<% else %>
  <%= helpers.turbo_frame_tag(
    @frame_id,
    src: @src_path,
    loading: :lazy,
    refresh: @refresh,
  ) {
    tag.div(class: "animate-pulse rounded-lg border border-[var(--pathogen-color-border-default)] bg-[var(--pathogen-color-surface-subtle)] p-4", aria: { hidden: true }) {
      tag.div(class: "grid gap-3") {
        safe_join([
          tag.div(class: "h-3.5 w-[32%] rounded-md bg-[color-mix(in_oklab,var(--pathogen-color-border-strong)_86%,transparent)]"),
          tag.div(class: "grid gap-2") {
            safe_join([
              tag.div(class: "h-2.5 w-full rounded-md bg-[color-mix(in_oklab,var(--pathogen-color-border-strong)_86%,transparent)]"),
              tag.div(class: "h-2.5 w-[92%] rounded-md bg-[color-mix(in_oklab,var(--pathogen-color-border-strong)_86%,transparent)]"),
              tag.div(class: "h-2.5 w-[84%] rounded-md bg-[color-mix(in_oklab,var(--pathogen-color-border-strong)_86%,transparent)]"),
              tag.div(class: "h-2.5 w-[84%] rounded-md bg-[color-mix(in_oklab,var(--pathogen-color-border-strong)_86%,transparent)]"),
              tag.div(class: "h-2.5 w-[84%] rounded-md bg-[color-mix(in_oklab,var(--pathogen-color-border-strong)_86%,transparent)]"),
              tag.div(class: "h-2.5 w-[84%] rounded-md bg-[color-mix(in_oklab,var(--pathogen-color-border-strong)_86%,transparent)]")
            ])
          }
        ])
      }
    }
  } %>
<% end %>
