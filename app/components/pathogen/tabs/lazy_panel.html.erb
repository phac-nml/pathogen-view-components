<% if render_eager? %>
  <%= helpers.turbo_frame_tag(@frame_id) { content } %>
<% else %>
  <%= helpers.turbo_frame_tag(
    @frame_id,
    src: @src_path,
    loading: :lazy,
    refresh: @refresh,
  ) {
    tag.div(class: class_names(Pathogen::TabsStyles::LAZY_PANEL_SKELETON), aria: { hidden: true }) {
      tag.div(class: "grid gap-3") {
        safe_join([
          tag.div(class: class_names("h-3.5 w-[32%]", Pathogen::TabsStyles::LAZY_PANEL_SKELETON_BAR)),
          tag.div(class: "grid gap-2") {
            safe_join([
              tag.div(class: class_names("h-2.5 w-full", Pathogen::TabsStyles::LAZY_PANEL_SKELETON_BAR)),
              tag.div(class: class_names("h-2.5 w-[92%]", Pathogen::TabsStyles::LAZY_PANEL_SKELETON_BAR)),
              tag.div(class: class_names("h-2.5 w-[84%]", Pathogen::TabsStyles::LAZY_PANEL_SKELETON_BAR)),
              tag.div(class: class_names("h-2.5 w-[84%]", Pathogen::TabsStyles::LAZY_PANEL_SKELETON_BAR)),
              tag.div(class: class_names("h-2.5 w-[84%]", Pathogen::TabsStyles::LAZY_PANEL_SKELETON_BAR)),
              tag.div(class: class_names("h-2.5 w-[84%]", Pathogen::TabsStyles::LAZY_PANEL_SKELETON_BAR))
            ])
          }
        ])
      }
    }
  } %>
<% end %>
