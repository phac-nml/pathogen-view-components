<%= render @base_button_class.new(**@system_arguments) do -%>
  <% if leading_visual %>
    <span class="pathogen-button__visual pathogen-button__visual--leading"><%= leading_visual %></span>
  <% end %>

  <span><%= trimmed_content %></span>

  <% if trailing_visual %>
    <span class="pathogen-button__visual pathogen-button__visual--trailing">
      <% if @trailing_visual_counter %>
        <span class="pathogen-u-sr-only">(<%= trailing_visual %>)</span>
        <%= trailing_visual %>
      <% else %>
        <%= trailing_visual %>
      <% end %>
    </span>
  <% end %>
<% end %>
