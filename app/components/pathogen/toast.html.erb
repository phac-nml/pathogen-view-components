<%= tag.li(**@system_arguments) do %>
  <div class="flex items-start gap-2 p-3">
    <span class="flex size-4 shrink-0 items-center justify-center <%= icon_color %>" aria-hidden="true">
      <svg
        class="size-4 shrink-0"
        viewBox="0 0 16 16"
        fill="currentColor"
        aria-hidden="true"
      >
        <%= icon_svg %>
      </svg>
    </span>

    <div class="min-w-0 flex-1">
      <p class="text-[length:var(--type-control)] font-semibold text-[var(--pvc-color-text)]">
        <span class="sr-only"><%= icon_label %>:</span>
        <span data-pathogen--toast-target="message"><%= message %></span>
      </p>

      <% if description.present? %>
        <p
          class="mt-1 text-[length:var(--type-control)] text-[var(--pvc-color-text-muted)]"
          data-pathogen--toast-target="description"
        >
          <%= description %>
        </p>
      <% end %>

      <% if action? %>
        <div class="mt-2">
          <%= action %>
        </div>
      <% end %>
    </div>

    <% if dismissible %>
      <%= render Pathogen::Button.new(
        size: :small,
        tone: :neutral,
        emphasis: :ghost,
        icon_only: true,
        text: t('pathogen.toast.dismiss'),
        'data-action': 'click->pathogen--toast#dismiss'
      ) do |button| %>
        <% button.with_leading_visual do %>
          <svg
            aria-hidden="true"
            width="12"
            height="12"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M12 4 4 12M4 4l8 8" />
          </svg>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
