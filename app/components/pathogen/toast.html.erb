<%= tag.li(**@system_arguments) do %>
  <%= content_tag(:div, **(dialog_mode? ? dialog_attributes : {})) do %>
    <div class="p-4">
      <div class="flex items-start gap-2">
        <span class="mt-0.5 flex size-4 shrink-0 items-center justify-center <%= icon_color %>" aria-hidden="true">
          <svg
            class="size-4 shrink-0"
            viewBox="0 0 16 16"
            fill="currentColor"
            aria-hidden="true"
          >
            <%= icon_svg %>
          </svg>
        </span>

        <div class="min-w-0 flex-1">
          <p class="text-[length:var(--type-control)] font-semibold text-[var(--pvc-color-text)]">
            <span id="<%= type_label_dom_id %>" class="sr-only" data-pathogen--toast-target="typeLabel">
              <%= icon_label %>:
            </span>

            <span
              id="<%= message_dom_id %>"
              class="break-words [overflow-wrap:anywhere]"
              data-pathogen--toast-target="message"
            >
              <%= message %>
            </span>
          </p>
        </div>

        <%= tag.div class: '-mr-1 shrink-0', data: { 'pathogen--toast-target': 'dismiss' }, hidden: !dismissible do %>
          <%= render Pathogen::Button.new(
            size: :small,
            tone: :neutral,
            emphasis: :ghost,
            icon_only: true,
            text: t('pathogen.toast.dismiss'),
            'data-action': 'click->pathogen--toast#dismiss'
          ) do |button| %>
            <% button.with_leading_visual do %>
              <svg
                aria-hidden="true"
                class="size-4"
                viewBox="0 0 16 16"
                fill="currentColor"
              >
                <path
                  d="M2.75 2.75a.625.625 0 0 1 .884 0L8 7.116l4.366-4.366a.625.625 0 0 1 .884.884L8.884 8l4.366 4.366a.625.625 0 0 1-.884.884L8 8.884l-4.366 4.366a.625.625 0 0 1-.884-.884L7.116 8 2.75 3.634a.625.625 0 0 1 0-.884Z"
                />
              </svg>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <% if description.present? || action? %>
        <div class="pl-6">
          <% if description.present? %>
            <p
              id="<%= description_dom_id %>"
              class="
                mt-1 break-words text-[length:var(--type-control)] text-[var(--pvc-color-text-muted)]
                [overflow-wrap:anywhere]
              "
              data-pathogen--toast-target="description"
            >
              <%= description %>
            </p>
          <% end %>

          <% if action? %>
            <div class="mt-2" data-pathogen--toast-target="action">
              <%= action %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
